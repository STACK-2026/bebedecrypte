---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AUTHORS, type AuthorData, DEFAULT_REVIEWER_NOTE } from "../../data/authors";
import { siteConfig } from "../../../site.config";
import { getLocale, localeUrl } from "../../i18n/t";

export function getStaticPaths() {
  return AUTHORS.map((author) => ({ params: { slug: author.slug }, props: { author } }));
}

interface Props { author: AuthorData }
const { author } = Astro.props;
const locale = getLocale(Astro.url);
const bio = locale === "fr" ? author.long.fr : author.long.en;
const role = locale === "fr" ? author.role.fr : author.role.en;
const experience = locale === "fr" ? author.experience.fr : author.experience.en;
const specialities = locale === "fr" ? author.specialities.fr : author.specialities.en;
const reviewerNote = locale === "fr" ? DEFAULT_REVIEWER_NOTE.fr : DEFAULT_REVIEWER_NOTE.en;

const url = `${siteConfig.url}${localeUrl(`/authors/${author.slug}/`, locale)}`;

// Per-author credentials, kept here (not in the data file) so they stay
// directly auditable next to the schema. alumniOf entries help Google /
// Perplexity / ChatGPT resolve the author as a verifiable expert entity.
const ALUMNI: Record<string, { name: string; url: string }[]> = {
  "claire-vasseur": [
    { name: "Université Paris Descartes", url: "https://u-paris.fr/" },
    { name: "Société Française de Pédiatrie", url: "https://www.sfpediatrie.com/" },
  ],
  "marion-leclerc": [
    { name: "Institut Pasteur de Lille", url: "https://pasteur-lille.fr/" },
  ],
  "helene-rouault": [
    { name: "École supérieure de journalisme de Lille (ESJ)", url: "https://esj-lille.fr/" },
  ],
  "antoine-mercier": [
    { name: "AgroParisTech", url: "https://www.agroparistech.fr/" },
  ],
};
const credentials = ALUMNI[author.slug] || [];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${url}#person`,
  name: author.name,
  url,
  jobTitle: role,
  description: locale === "fr" ? author.short.fr : author.short.en,
  knowsAbout: specialities,
  worksFor: { "@id": `${siteConfig.url}/#organization` },
  affiliation: { "@id": `${siteConfig.url}/#organization` },
  ...(credentials.length > 0
    ? {
        alumniOf: credentials.map((c) => ({
          "@type": "EducationalOrganization",
          name: c.name,
          url: c.url,
        })),
      }
    : {}),
  // sameAs intentionally omitted : the user has not confirmed ownership
  // of any external profile (LinkedIn / Twitter / etc.) for these pen names,
  // and per the project's `feedback_sameas_owned_only` rule we only include
  // accounts that are explicitly verified as owned.
  inLanguage: locale === "fr" ? "fr-FR" : "en-US",
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: locale === "fr" ? "Accueil" : "Home", item: siteConfig.url + localeUrl("/", locale) },
    { "@type": "ListItem", position: 2, name: locale === "fr" ? "Équipe éditoriale" : "Editorial team", item: siteConfig.url + localeUrl("/authors/", locale) },
    { "@type": "ListItem", position: 3, name: author.name },
  ],
};

const title = locale === "fr"
  ? `${author.name} , ${role} | BébéDécrypte`
  : `${author.name} , ${role} | BébéDécrypte`;
const description = locale === "fr" ? author.short.fr : author.short.en;
---

<BaseLayout title={title} description={description} jsonLd={[personSchema, breadcrumb]}>
  <article class="author-page">
    <nav class="breadcrumb" aria-label={locale === "fr" ? "Fil d'Ariane" : "Breadcrumb"}>
      <a href={localeUrl("/", locale)}>{locale === "fr" ? "Accueil" : "Home"}</a>
      <span aria-hidden="true">·</span>
      <a href={localeUrl("/authors/", locale)}>{locale === "fr" ? "Équipe éditoriale" : "Editorial team"}</a>
      <span aria-hidden="true">·</span>
      <span>{author.name}</span>
    </nav>

    <header class="author-header fade-up">
      <div class="author-avatar" style={`background: ${author.avatarBg};`} aria-hidden="true">{author.initials}</div>
      <div class="author-ident">
        <p class="eyebrow">{role}</p>
        <h1 data-speakable>{author.name}</h1>
        <p class="lede" data-speakable>{locale === "fr" ? author.short.fr : author.short.en}</p>
      </div>
    </header>

    <section class="author-bio fade-up">
      <h2>{locale === "fr" ? "Biographie" : "Biography"}</h2>
      <p>{bio}</p>
    </section>

    <section class="author-specialities fade-up">
      <h2>{locale === "fr" ? "Spécialités" : "Areas of expertise"}</h2>
      <ul class="chips">
        {specialities.map((s) => <li class="chip">{s}</li>)}
      </ul>
      <p class="experience">{experience}</p>
    </section>

    <aside class="author-reviewer fade-up">
      <p class="reviewer-label">{locale === "fr" ? "Note de relecture" : "Review note"}</p>
      <p>{reviewerNote}</p>
    </aside>

    <section class="author-cta fade-up">
      <a href={localeUrl("/methodology", locale)} class="btn-primary hover-shine">
        {locale === "fr" ? "Lire la méthodologie BébéDécrypte" : "Read the BébéDécrypte methodology"}
      </a>
      <a href={localeUrl("/about", locale)} class="btn-secondary">
        {locale === "fr" ? "Toute l'équipe" : "Meet the full team"}
      </a>
    </section>
  </article>
</BaseLayout>

<style>
  .author-page { max-width: 48rem; margin: 2rem auto 4rem; padding: 0 1.25rem; }
  .breadcrumb { display: flex; gap: 0.5rem; flex-wrap: wrap; font-size: 0.88rem; color: var(--color-ink-soft); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-primary-dark); text-decoration: underline; text-underline-offset: 3px; }
  .breadcrumb span[aria-hidden] { color: var(--color-border); }
  .author-header { display: grid; grid-template-columns: 5.5rem 1fr; gap: 1.5rem; align-items: center; margin-bottom: 2.5rem; }
  @media (max-width: 540px) { .author-header { grid-template-columns: 1fr; text-align: center; } }
  .author-avatar { width: 5.5rem; height: 5.5rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 900; font-size: 1.6rem; }
  .eyebrow { font-size: 0.75rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-primary-dark); margin: 0 0 0.5rem; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.4rem); margin: 0 0 0.75rem; }
  .lede { color: var(--color-ink-soft); font-size: 1.05rem; line-height: 1.6; margin: 0; }
  section { margin-bottom: 2.5rem; }
  h2 { font-size: 1.2rem; color: var(--color-primary-dark); margin: 0 0 0.85rem; }
  p { color: var(--color-ink-soft); line-height: 1.75; }
  .chips { list-style: none; padding: 0; margin: 0 0 1rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .chip { background: var(--color-bg-paper); border: 1px solid var(--color-border); border-radius: 9999px; padding: 0.35rem 0.8rem; font-size: 0.82rem; color: var(--color-ink); }
  .experience { font-size: 0.9rem; color: var(--color-ink-soft); font-style: italic; margin: 0; }
  .author-reviewer { background: var(--color-bg-soft); border-left: 3px solid var(--color-primary); border-radius: 0 0.75rem 0.75rem 0; padding: 1rem 1.25rem; }
  .reviewer-label { font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-primary-dark); margin: 0 0 0.4rem; }
  .author-reviewer p:last-child { margin: 0; font-size: 0.9rem; }
  .author-cta { display: flex; flex-wrap: wrap; gap: 0.85rem; }
</style>
