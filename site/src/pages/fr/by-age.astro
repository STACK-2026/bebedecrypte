---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ComingSoonPage from "../../components/sections/ComingSoonPage.astro";

const copy = {
  eyebrow: { fr: "Par âge", en: "By age" },
  title: {
    fr: "Les produits filtrés par âge, du 4 mois au 3 ans",
    en: "Products filtered by age, from 4 months to 3 years",
  },
  lede: {
    fr: "Chaque âge a ses règles : avant 6 mois, que du lait maternel ou du lait infantile 1er âge. De 6 à 12 mois, diversification progressive, aucun sucre ajouté, aucun miel. De 12 à 36 mois, introduction prudente des textures et des saveurs. Notre pondération s'adapte automatiquement : plus strict avant 12 mois.",
    en: "Every age has its rules: before 6 months, breast milk or first-age formula only. 6 to 12 months, progressive complementary feeding, no added sugar, no honey. 12 to 36 months, careful introduction of textures and flavours. Our weighting adapts automatically: stricter before 12 months.",
  },
  expect: {
    fr: [
      "Pages dédiées 4 mois, 6 mois, 8 mois, 12 mois, 18 mois, 24 mois, 3 ans et +",
      "Pour chaque âge : les produits adaptés du catalogue, notés A à E, triés par score",
      "Guide pratique de ce qui est autorisé, recommandé et interdit à chaque âge",
      "Les produits marketing « dès X mois » dont la composition ne tient pas la promesse",
    ],
    en: [
      "Dedicated pages for 4m, 6m, 8m, 12m, 18m, 24m, 3 years and up",
      "For each age : age-appropriate catalog products, graded A to E, sorted by score",
      "Practical guide of what is allowed, recommended, forbidden at each age",
      "Products marketed \"from X months\" whose composition does not match the claim",
    ],
  },
  eta: {
    fr: "Ouverture prévue , semaine du 29 avril 2026, avec le catalogue.",
    en: "Planned opening , week of 29 April 2026, with the catalog.",
  },
};

const title = "Alimentation bébé par âge | BébéDécrypte";
const description =
  "Sélection de produits bébé filtrés par âge (4m, 6m, 8m, 12m, 18m, 24m, 3 ans+). Guides de diversification et pondération stricte avant 12 mois.";
---

<BaseLayout title={title} description={description}>
  <ComingSoonPage slug="by-age" copy={copy} />
</BaseLayout>
