---
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutPage from "../components/sections/AboutPage.astro";
import { siteConfig } from "../../site.config";

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "À propos" },
  ],
};

const aboutPage = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": `${siteConfig.url}/about/#about`,
  url: `${siteConfig.url}/about/`,
  name: "À propos de BébéDécrypte",
  description: "Service éditorial indépendant de notation des produits pour bébé, relu par une pédiatre.",
  publisher: { "@id": `${siteConfig.url}/#organization` },
  inLanguage: "fr-FR",
};
---

<BaseLayout
  title="À propos de BébéDécrypte , Décodeur d'alimentation bébé indépendant"
  description="BébéDécrypte est un service éditorial européen indépendant qui note chaque petit pot, lait infantile, céréale et gourde bébé de A à E. Méthodologie en 8 axes, transparente, relue par une pédiatre nutritionniste, aucune marque ne paie."
  jsonLd={[aboutPage, breadcrumb]}
>
  <AboutPage />
</BaseLayout>
