---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";

const brandsCol = await getCollection("brands");
const productsCol = await getCollection("products");

const brands = brandsCol
  .map((b) => {
    const products = productsCol.filter((p) => p.data.brandSlug === b.data.slug);
    return {
      slug: b.data.slug,
      name: b.data.brand,
      averageGrade: b.data.averageGrade as string,
      averageScore: b.data.averageScore as number,
      productCount: products.length,
    };
  })
  .filter((b) => b.productCount > 0)
  .sort((a, z) => a.name.localeCompare(z.name, "fr"));

const byLetter: Record<string, typeof brands> = {};
for (const b of brands) {
  const letter = b.name.charAt(0).toUpperCase();
  const key = /[A-Z]/.test(letter) ? letter : "#";
  (byLetter[key] ||= []).push(b);
}
const letters = Object.keys(byLetter).sort();

const title = "Toutes les marques d'alimentation bébé notées A à E | BébéDécrypte";
const description = `${brands.length} marques d'alimentation bébé analysées et notées sur 8 axes (NOVA, additifs, sucres cachés, bio, allergènes). Blédina, Babybio, Good Goût, Gallia, Nestlé, Popote, Yooji et plus.`;

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Toutes les marques d'alimentation bébé notées",
  numberOfItems: brands.length,
  itemListElement: brands.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${siteConfig.url}/brands/${b.slug}/`,
    name: b.name,
  })),
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "Marques", item: siteConfig.url + "/brands/" },
  ],
};

const gradeColors: Record<string, string> = {
  A: "var(--grade-a)",
  B: "var(--grade-b)",
  C: "var(--grade-c)",
  D: "var(--grade-d)",
  E: "var(--grade-e)",
};
---

<BaseLayout title={title} description={description} jsonLd={[itemList, breadcrumb]}>
  <article class="hub-page">
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> <span aria-hidden="true">·</span>
      <span>Marques</span>
    </nav>

    <header class="hub-header fade-up">
      <p class="eyebrow">Annuaire</p>
      <h1 data-speakable>Toutes les marques d'alimentation bébé</h1>
      <p class="lede" data-speakable>
        {brands.length} marques analysées sur 8 axes bébé : ultra-transformation NOVA, additifs EFSA, sucres cachés, Nutri-Score, bio, allergènes, origine, simplicité. Cliquez une marque pour voir ses produits notés de A à E.
      </p>
    </header>

    <nav class="alpha-nav" aria-label="Navigation alphabétique">
      {letters.map((l) => <a href={`#letter-${l}`}>{l}</a>)}
    </nav>

    {letters.map((l) => (
      <section class="letter-block fade-up" id={`letter-${l}`}>
        <h2 class="letter-heading">{l}</h2>
        <ul class="brand-list">
          {byLetter[l].map((b) => (
            <li>
              <a href={`/brands/${b.slug}/`} class="brand-card">
                <span class="b-grade-pill" style={`background: ${gradeColors[b.averageGrade] || "#0891b2"};`}>{b.averageGrade}</span>
                <span class="b-name">{b.name}</span>
                <span class="b-count">{b.productCount} produit{b.productCount > 1 ? "s" : ""}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </article>
</BaseLayout>

<style>
  .hub-page { max-width: 64rem; margin: 2rem auto 4rem; padding: 0 1.25rem; }
  .breadcrumb { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.82rem; color: var(--color-ink-soft); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-primary-dark); text-decoration: underline; text-underline-offset: 3px; }
  .hub-header { margin-bottom: 2rem; }
  .eyebrow { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-primary-dark); margin: 0 0 0.5rem; }
  .hub-header h1 { font-size: clamp(1.75rem, 4vw, 2.4rem); margin: 0 0 0.75rem; }
  .lede { color: var(--color-ink-soft); max-width: 46rem; line-height: 1.6; margin: 0; }
  .alpha-nav { display: flex; flex-wrap: wrap; gap: 0.4rem; padding: 0.75rem; background: var(--color-bg-soft); border-radius: 0.75rem; margin-bottom: 2rem; position: sticky; top: 1rem; z-index: 5; backdrop-filter: blur(6px); }
  .alpha-nav a { font-family: var(--font-display); font-weight: 700; font-size: 0.85rem; color: var(--color-primary-dark); text-decoration: none; padding: 0.3rem 0.55rem; border-radius: 0.4rem; transition: background 200ms ease; }
  .alpha-nav a:hover { background: rgb(255 255 255 / 0.6); }
  .letter-block { margin-bottom: 2rem; scroll-margin-top: 5rem; }
  .letter-heading { font-family: var(--font-display); font-size: 1.5rem; color: var(--color-primary-dark); margin: 0 0 0.75rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.35rem; }
  .brand-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: 0.5rem; }
  .brand-card { display: flex; align-items: center; gap: 0.65rem; padding: 0.65rem 0.85rem; background: #fff; border: 1px solid var(--color-border); border-radius: 0.625rem; text-decoration: none; color: inherit; transition: border-color 200ms ease, transform 200ms var(--ease-out-expo); }
  .brand-card:hover { border-color: var(--color-primary); transform: translateY(-1px); }
  .b-grade-pill { display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 0.45rem; color: #fff; font-family: var(--font-display); font-weight: 800; font-size: 0.95rem; flex-shrink: 0; }
  .b-name { flex: 1; font-weight: 600; color: var(--color-ink); }
  .b-count { font-size: 0.75rem; color: var(--color-ink-soft); font-variant-numeric: tabular-nums; }
</style>
