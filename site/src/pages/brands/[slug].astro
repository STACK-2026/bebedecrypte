---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "../../../site.config";

export async function getStaticPaths() {
  const brands = await getCollection("brands");
  const products = await getCollection("products");
  return brands.map((b) => ({
    params: { slug: b.data.slug },
    props: {
      brand: b,
      products: products.filter((p) => p.data.brandSlug === b.data.slug).sort((a, z) => z.data.score - a.data.score),
    },
  }));
}

const { brand, products } = Astro.props;
const { data } = brand;
const { Content: BrandBody } = await render(brand);

// CTR-optimised title and description : brand + volume + grade + brand BébéDécrypte
const optimisedTitle = `${data.brand} : ${products.length} produit${products.length > 1 ? "s" : ""} bébé noté${products.length > 1 ? "s" : ""} (moyenne ${data.averageGrade}) | BébéDécrypte`;
const gradeLabel: Record<string, string> = {
  A: "majoritairement A et B",
  B: "globalement bien noté",
  C: "qualité moyenne, à comparer recette par recette",
  D: "qualité insuffisante, à éviter sur la plupart des recettes",
  E: "fortement déconseillé sur la quasi-totalité des produits",
};
const optimisedDescription = `Note moyenne ${data.averageGrade} (${data.averageScore}/100) sur ${products.length} produit${products.length > 1 ? "s" : ""} ${data.brand} analysé${products.length > 1 ? "s" : ""} par BébéDécrypte. Marque ${gradeLabel[data.averageGrade] || "analysée sur 8 axes bébé"}. Sources ANSES, EFSA, Open Food Facts.`.slice(0, 200);

// FAQ : 3 standardised questions per brand for FAQPage rich result
const topProducts = products.slice(0, 3);
const brandFaq = [
  {
    question: `Quelle est la note moyenne de la marque ${data.brand} ?`,
    answer: `${data.brand} obtient une note moyenne ${data.averageGrade} (${data.averageScore}/100) sur ${products.length} produit${products.length > 1 ? "s" : ""} analysé${products.length > 1 ? "s" : ""} par BébéDécrypte. La pondération suit notre méthodologie 8 axes (NOVA, additifs EFSA, sucres cachés, Nutri-Score, bio, allergènes, origine, simplicité de recette).`,
  },
  {
    question: `Quels sont les meilleurs produits ${data.brand} pour bébé ?`,
    answer: topProducts.length > 0
      ? `Les ${topProducts.length} mieux notés : ${topProducts.map((p: any) => `${p.data.name} (${p.data.grade}, ${p.data.score}/100)`).join(" ; ")}. Voir la liste complète plus bas.`
      : `Aucun produit ${data.brand} n'est encore référencé dans notre catalogue.`,
  },
  {
    question: `${data.brand} est-elle une marque indépendante ou industrielle ?`,
    answer: `BébéDécrypte ne juge pas l'appartenance industrielle. Le scoring est purement basé sur la composition des produits, leurs additifs et leurs sucres cachés. La même marque peut avoir simultanément des produits A et des produits E selon la recette.`,
  },
];
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: brandFaq.map((q) => ({
    "@type": "Question",
    name: q.question,
    acceptedAnswer: { "@type": "Answer", text: q.answer },
  })),
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "Catalogue", item: siteConfig.url + "/products/" },
    { "@type": "ListItem", position: 3, name: data.brand },
  ],
};

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Produits ${data.brand}`,
  numberOfItems: products.length,
  itemListElement: products.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${siteConfig.url}/products/${p.data.slug}/`,
    name: p.data.name,
  })),
};

const brandLd = {
  "@context": "https://schema.org",
  "@type": "Brand",
  "@id": `${siteConfig.url}/brands/${data.slug}/#brand`,
  name: data.brand,
  url: `${siteConfig.url}/brands/${data.slug}/`,
  ...(products.length > 0
    ? {
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: data.averageScore,
          bestRating: 100,
          worstRating: 0,
          ratingCount: products.length,
          reviewCount: products.length,
          alternateName: data.averageGrade,
        },
      }
    : {}),
};

const gradeColors: Record<string, string> = { A: "var(--grade-a)", B: "var(--grade-b)", C: "var(--grade-c)", D: "var(--grade-d)", E: "var(--grade-e)" };
---

<BaseLayout title={optimisedTitle} description={optimisedDescription} jsonLd={[brandLd, itemList, breadcrumb, faqLd]} localized={false}>
  <article class="brand-page">
    <nav class="breadcrumb">
      <a href="/">Accueil</a> <span aria-hidden="true">·</span>
      <a href="/products/">Catalogue</a> <span aria-hidden="true">·</span>
      <span>{data.brand}</span>
    </nav>

    <header class="b-header fade-up">
      <div class="b-grade" style={`background: ${gradeColors[data.averageGrade] || "#0891b2"};`} aria-label={`Note moyenne ${data.averageGrade}`}>
        <span class="b-grade-letter">{data.averageGrade}</span>
        <span class="b-grade-score">{data.averageScore}/100</span>
      </div>
      <div class="b-title">
        <p class="eyebrow">Marque</p>
        <h1 data-speakable>{data.brand}</h1>
        <p class="lede" data-speakable>{data.description}</p>
        <p class="b-count">{data.productCount} produit(s) au catalogue BébéDécrypte</p>
      </div>
    </header>

    <section class="b-body fade-up prose">
      <BrandBody />
    </section>

    <section class="b-products fade-up">
      <h2>Tous les produits {data.brand} notés</h2>
      <ul class="b-products-list">
        {products.map((p: any) => (
          <li>
            <a href={`/products/${p.data.slug}/`} class="b-product-card">
              <span class={`grade grade-sm grade-${p.data.grade.toLowerCase()}`}>{p.data.grade}</span>
              <span class="b-product-name">{p.data.name}</span>
              <span class="b-product-score">{p.data.score}/100</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="b-faq fade-up" aria-labelledby="brand-faq">
      <h2 id="brand-faq">Questions fréquentes sur {data.brand}</h2>
      <dl class="faq-list">
        {brandFaq.map((q) => (
          <>
            <dt class="faq-q" data-speakable>{q.question}</dt>
            <dd class="faq-a" data-speakable>{q.answer}</dd>
          </>
        ))}
      </dl>
    </section>
  </article>
</BaseLayout>

<style>
  .brand-page { max-width: 56rem; margin: 2rem auto 4rem; padding: 0 1.25rem; }
  .breadcrumb { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.82rem; color: var(--color-ink-soft); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-primary-dark); text-decoration: underline; text-underline-offset: 3px; }
  .b-header { display: grid; grid-template-columns: auto 1fr; gap: 1.5rem; margin-bottom: 2rem; align-items: center; }
  @media (max-width: 640px) { .b-header { grid-template-columns: 1fr; text-align: center; } }
  .b-grade { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 6rem; height: 6rem; border-radius: 1rem; color: #fff; box-shadow: 0 8px 28px -6px rgb(12 10 9 / 0.25); }
  .b-grade-letter { font-family: var(--font-display); font-weight: 900; font-size: 2.5rem; line-height: 1; }
  .b-grade-score { font-size: 0.75rem; opacity: 0.85; }
  .eyebrow { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-primary-dark); margin: 0 0 0.5rem; }
  .b-title h1 { font-size: clamp(1.75rem, 4vw, 2.4rem); margin: 0 0 0.5rem; }
  .lede { color: var(--color-ink-soft); margin: 0 0 0.5rem; }
  .b-count { font-size: 0.85rem; color: var(--color-ink-soft); margin: 0; font-style: italic; }
  .b-body { margin: 2rem 0; }
  .b-products { margin-top: 2rem; }
  .b-products h2 { font-size: 1.3rem; color: var(--color-primary-dark); margin: 0 0 1rem; }
  .b-products-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem; }
  .b-product-card { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: #fff; border: 1px solid var(--color-border); border-radius: 0.625rem; text-decoration: none; color: inherit; transition: border-color 200ms ease, transform 200ms var(--ease-out-expo); }
  .b-product-card:hover { border-color: var(--color-primary); transform: translateY(-1px); }
  .b-product-name { flex: 1; color: var(--color-ink); }
  .b-product-score { font-size: 0.82rem; color: var(--color-ink-soft); font-variant-numeric: tabular-nums; }
  .b-faq { background: #fff; border: 1px solid var(--color-border); border-radius: 0.875rem; padding: 1.25rem 1.4rem; margin-top: 2rem; }
  .b-faq h2 { font-size: 1.1rem; color: var(--color-primary-dark); margin: 0 0 0.85rem; }
  .b-faq .faq-list { display: flex; flex-direction: column; gap: 0.85rem; margin: 0; }
  .b-faq .faq-q { font-weight: 700; color: var(--color-ink); font-size: 0.95rem; margin: 0; }
  .b-faq .faq-a { font-size: 0.9rem; color: var(--color-ink-soft); line-height: 1.6; margin: 0.25rem 0 0; }
</style>
