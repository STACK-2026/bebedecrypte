---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../../site.config";
import { tr, t, getLocale, localeUrl } from "../i18n/t";

const locale = getLocale(Astro.url);
---

<BaseLayout
  title={`${t(tr.notFound.title, locale)} | ${siteConfig.name}`}
  description={t(tr.notFound.body, locale)}
  noIndex
>
  <section class="notfound">
    <div class="notfound-decor" aria-hidden="true">
      <svg viewBox="0 0 120 120" fill="none">
        <defs>
          <linearGradient id="bowlGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#16a34a" stop-opacity="0.18"/>
            <stop offset="100%" stop-color="#065f46" stop-opacity="0.08"/>
          </linearGradient>
        </defs>
        <ellipse cx="60" cy="78" rx="42" ry="28" fill="url(#bowlGrad)" stroke="#16a34a" stroke-width="2.5"/>
        <ellipse cx="60" cy="70" rx="42" ry="10" fill="none" stroke="#16a34a" stroke-width="2"/>
      </svg>
      <div class="crumbs">
        <span class="crumb paw-wave"></span>
        <span class="crumb paw-wave delay-1"></span>
        <span class="crumb paw-wave delay-2"></span>
      </div>
    </div>

    <div class="notfound-inner">
      <p class="code grade-stamp" aria-hidden="true">{t(tr.notFound.code, locale)}</p>
      <h1>{t(tr.notFound.title, locale)}</h1>
      <p class="lede">{t(tr.notFound.body, locale)}</p>

      <div class="notfound-ctas">
        <a href={localeUrl("/", locale)} class="btn-primary">
          {t(tr.notFound.home, locale)}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href={siteConfig.appUrl} class="btn-secondary">{t(tr.notFound.score, locale)}</a>
      </div>

      <div class="notfound-links">
        <p class="links-title">{t(tr.notFound.popular, locale)}</p>
        <ul>
          <li><a href={localeUrl("/rankings", locale)}><span class="grade grade-sm grade-a">A</span> {t(tr.nav.catalogue, locale)}</a></li>
          <li><a href={localeUrl("/compare", locale)}><span class="grade grade-sm grade-b">B</span> {t(tr.nav.compare, locale)}</a></li>
          <li><a href={localeUrl("/encyclopedia", locale)}><span class="grade grade-sm grade-c">C</span> {t(tr.nav.additives, locale)}</a></li>
          <li><a href={localeUrl("/methodology", locale)}><span class="grade grade-sm grade-d">D</span> {t(tr.nav.methodology, locale)}</a></li>
          <li><a href={localeUrl("/blog", locale)}><span class="grade grade-sm grade-e">E</span> {t(tr.nav.blog, locale)}</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding: 5rem 1rem 6rem;
    background: linear-gradient(180deg, var(--color-bg-soft) 0%, #ffffff 60%);
    min-height: 70vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .notfound-decor {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 160px;
    pointer-events: none;
    opacity: 0.9;
  }
  .crumbs {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
  .crumb {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 9999px;
    background: var(--color-accent);
    display: inline-block;
  }
  .notfound-inner {
    max-width: 44rem;
    margin: 7rem auto 0;
    text-align: center;
    position: relative;
  }
  .code {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 12vw, 7.5rem);
    font-weight: 900;
    line-height: 0.95;
    margin: 0 0 0.5rem;
    background: linear-gradient(135deg, rgb(22 163 74 / 0.9), rgb(6 95 70 / 0.4));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    letter-spacing: -0.04em;
  }
  .notfound h1 {
    margin-bottom: 1rem;
  }
  .lede {
    color: var(--color-ink-soft);
    font-size: 1.1rem;
    max-width: 34rem;
    margin: 0 auto 2rem;
  }
  .notfound-ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }
  .notfound-links {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.75rem 2rem;
    text-align: left;
    box-shadow: var(--shadow-card);
  }
  .links-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 800;
    color: var(--color-ink-soft);
    margin-bottom: 1rem;
  }
  .notfound-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }
  @media (min-width: 640px) {
    .notfound-links ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .notfound-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.4rem;
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    border-radius: 0.5rem;
    transition: all 200ms ease;
  }
  .notfound-links a:hover {
    background: var(--color-bg-soft);
    color: var(--color-primary-dark);
    transform: translateX(2px);
  }
</style>
