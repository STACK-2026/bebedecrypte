---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";

const productsCol = await getCollection("products");
const catsCol = await getCollection("categories");
const brandsCol = await getCollection("brands");

const allProducts = productsCol
  .map((p) => ({
    slug: p.data.slug,
    brand: p.data.brand,
    brandSlug: p.data.brandSlug,
    name: p.data.name,
    grade: p.data.grade as string,
    score: p.data.score as number,
    catalogCategory: p.data.catalogCategory as string,
    targetAgeMonths: (p.data.targetAgeMonths as number) || 0,
  }))
  .sort((a, z) => z.score - a.score);

const byGrade: Record<string, number> = { A: 0, B: 0, C: 0, D: 0, E: 0 };
for (const p of allProducts) byGrade[p.grade] = (byGrade[p.grade] || 0) + 1;

const categories = catsCol
  .map((c) => ({
    slug: c.data.slug,
    title: c.data.title,
    productCount: allProducts.filter((p) => p.catalogCategory === c.data.slug).length,
  }))
  .sort((a, z) => z.productCount - a.productCount);

const brands = brandsCol
  .map((b) => ({ slug: b.data.slug, brand: b.data.brand, productCount: b.data.productCount }))
  .sort((a, z) => z.productCount - a.productCount);

// Age brackets aligned with /by-age/ : 4-6m, 6-8m, 8-12m, 12-18m, 18-24m, 24-36m, 36m+
const ageBrackets = [
  { key: "4m", label: "Dès 4 mois", min: 4, max: 5 },
  { key: "6m", label: "Dès 6 mois", min: 6, max: 7 },
  { key: "8m", label: "Dès 8 mois", min: 8, max: 11 },
  { key: "12m", label: "Dès 12 mois", min: 12, max: 17 },
  { key: "18m", label: "Dès 18 mois", min: 18, max: 23 },
  { key: "24m", label: "Dès 24 mois", min: 24, max: 35 },
  { key: "36m", label: "3 ans et +", min: 36, max: 72 },
];
function ageBracketFor(months: number): string {
  if (!months) return "any";
  for (const b of ageBrackets) {
    if (months >= b.min && months <= b.max) return b.key;
  }
  return "any";
}

const title = `Comparateur produits bébé : ${allProducts.length} aliments notés A à E | BébéDécrypte`;
const description = `Filtre ${allProducts.length} produits d'alimentation bébé par marque (${brands.length} marques), catégorie, âge et note A à E. Recherche instantanée. Notation indépendante 8 axes (NOVA, additifs, sucres cachés, bio).`;

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Catalogue BébéDécrypte des produits bébé notés",
  numberOfItems: allProducts.length,
  itemListElement: allProducts.slice(0, 100).map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${siteConfig.url}/products/${p.slug}/`,
    name: `${p.brand} ${p.name}`,
  })),
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "Produits", item: siteConfig.url + "/products/" },
  ],
};

const gradeColors: Record<string, string> = {
  A: "var(--grade-a)",
  B: "var(--grade-b)",
  C: "var(--grade-c)",
  D: "var(--grade-d)",
  E: "var(--grade-e)",
};
---

<BaseLayout title={title} description={description} jsonLd={[itemList, breadcrumb]} localized={false}>
  <article class="hub-page">
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> <span aria-hidden="true">·</span>
      <span>Produits</span>
    </nav>

    <header class="hub-header fade-up">
      <p class="eyebrow">Catalogue indépendant</p>
      <h1 data-speakable>{allProducts.length} produits bébé notés de A à E</h1>
      <p class="lede" data-speakable>
        Filtre par marque, catégorie, âge ou note. Chaque produit est analysé sur 8 axes bébé : NOVA (ultra-transformation), additifs EFSA, sucres cachés (maltodextrine, sirop de glucose, miel), Nutri-Score, bio, allergènes, origine, simplicité de recette. Données Open Food Facts, scoring déterministe, aucune marque ne paie.
      </p>
      <ul class="grade-summary" aria-label="Répartition des notes">
        {(["A", "B", "C", "D", "E"] as const).map((g) => (
          <li><span class="g-pill" style={`background:${gradeColors[g]};`}>{g}</span><strong>{byGrade[g]}</strong></li>
        ))}
      </ul>
    </header>

    <section class="filters fade-up" aria-label="Recherche et filtres">
      <div class="search-row">
        <label class="search-label" for="catalog-search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
          <input
            id="catalog-search"
            type="search"
            placeholder="Rechercher une marque, un produit, un ingrédient..."
            autocomplete="off"
            aria-label="Rechercher dans le catalogue" />
        </label>
        <div class="result-count" id="result-count" aria-live="polite">{allProducts.length} produits</div>
      </div>

      <div class="filter-row">
        <details class="filter-group">
          <summary>Note <span class="active-count" data-filter-active="grade"></span></summary>
          <div class="pill-list">
            {(["A", "B", "C", "D", "E"] as const).map((g) => (
              <label class="pill"><input type="checkbox" name="grade" value={g} /><span class="pill-label" style={`--pill-bg:${gradeColors[g]};`}>{g}</span></label>
            ))}
          </div>
        </details>

        <details class="filter-group">
          <summary>Catégorie <span class="active-count" data-filter-active="category"></span></summary>
          <div class="pill-list">
            {categories.map((c) => (
              <label class="pill"><input type="checkbox" name="category" value={c.slug} /><span class="pill-label">{c.title} <span class="pill-count">{c.productCount}</span></span></label>
            ))}
          </div>
        </details>

        <details class="filter-group">
          <summary>Âge <span class="active-count" data-filter-active="age"></span></summary>
          <div class="pill-list">
            {ageBrackets.map((a) => (
              <label class="pill"><input type="checkbox" name="age" value={a.key} /><span class="pill-label">{a.label}</span></label>
            ))}
          </div>
        </details>

        <details class="filter-group filter-brand">
          <summary>Marque <span class="active-count" data-filter-active="brand"></span></summary>
          <input type="search" id="brand-search" placeholder="Filtrer marques..." class="brand-search" aria-label="Filtrer la liste des marques" />
          <div class="brand-list">
            {brands.map((b) => (
              <label class="pill brand-pill" data-brand-name={b.brand.toLowerCase()}>
                <input type="checkbox" name="brand" value={b.slug} />
                <span class="pill-label">{b.brand} <span class="pill-count">{b.productCount}</span></span>
              </label>
            ))}
          </div>
        </details>

        <button type="button" id="reset-filters" class="reset-btn">Réinitialiser</button>
      </div>
    </section>

    <section class="catalog-section">
      <ul id="catalog-grid" class="catalog-grid" aria-label={`Liste des ${allProducts.length} produits notés`}>
        {allProducts.map((p) => (
          <li
            class="cat-card"
            data-grade={p.grade}
            data-category={p.catalogCategory}
            data-brand={p.brandSlug}
            data-age={ageBracketFor(p.targetAgeMonths)}
            data-search={(p.brand + " " + p.name + " " + p.catalogCategory).toLowerCase()}
          >
            <a href={`/products/${p.slug}/`}>
              <span class="c-grade" style={`background:${gradeColors[p.grade]};`} aria-label={`Note ${p.grade}`}>{p.grade}</span>
              <span class="c-score">{p.score}</span>
              <span class="c-meta">
                <span class="c-brand">{p.brand}</span>
                <span class="c-name">{p.name}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
      <p class="empty-state" id="empty-state" hidden>
        Aucun produit ne correspond à tes filtres. Essaie d'élargir la recherche ou <button type="button" class="link-button" onclick="document.getElementById('reset-filters').click()">remets tout à zéro</button>.
      </p>
      <p class="catalog-footnote">
        <a href="/methodology/">Voir la méthodologie complète</a> · <a href="/encyclopedia/">Encyclopédie des additifs</a> · <a href="/by-age/">Catalogue par âge</a>
      </p>
    </section>

    <section class="browse-section fade-up">
      <h2 class="section-title">Parcourir autrement</h2>
      <p class="section-lede">{categories.length} catégories couvrant {brands.length} marques, des géants industriels aux marques bio.</p>
      <p class="quick-links">
        <a href="/categories/" class="btn-secondary">Toutes les catégories &rarr;</a>
        <a href="/brands/" class="btn-secondary">Toutes les marques &rarr;</a>
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .hub-page { max-width: 72rem; margin: 2rem auto 4rem; padding: 0 1.25rem; }
  .breadcrumb { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.82rem; color: var(--color-ink-soft); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-primary-dark); text-decoration: underline; text-underline-offset: 3px; }
  .hub-header { margin-bottom: 2rem; }
  .eyebrow { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-primary-dark); margin: 0 0 0.5rem; }
  .hub-header h1 { font-size: clamp(1.75rem, 4vw, 2.4rem); margin: 0 0 0.75rem; line-height: 1.15; }
  .lede { color: var(--color-ink-soft); max-width: 50rem; line-height: 1.6; margin: 0 0 1.25rem; }
  .grade-summary { display: flex; flex-wrap: wrap; gap: 0.6rem; padding: 0; margin: 0; list-style: none; }
  .grade-summary li { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.86rem; color: var(--color-ink-soft); background: #fff; border: 1px solid var(--color-border); padding: 0.3rem 0.7rem; border-radius: 999px; }
  .grade-summary strong { font-variant-numeric: tabular-nums; color: var(--color-ink); }
  .g-pill { display: inline-flex; align-items: center; justify-content: center; width: 1.5rem; height: 1.5rem; border-radius: 0.4rem; color: #fff; font-family: var(--font-display); font-weight: 800; font-size: 0.85rem; }

  .filters { position: sticky; top: 0.5rem; z-index: 10; background: var(--color-bg, #fefce8); padding: 1rem; border: 1px solid var(--color-border); border-radius: 0.875rem; box-shadow: 0 4px 18px -10px #0c0a091f; margin: 1.5rem 0; }
  .search-row { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .search-label { display: flex; align-items: center; gap: 0.5rem; flex: 1 1 22rem; padding: 0.6rem 0.9rem; background: #fff; border: 1.5px solid var(--color-border); border-radius: 0.75rem; transition: border-color 200ms ease; }
  .search-label:focus-within { border-color: var(--color-primary); }
  .search-label svg { color: var(--color-ink-soft); flex-shrink: 0; }
  .search-label input { flex: 1; border: 0; outline: 0; font-size: 0.95rem; background: transparent; color: var(--color-ink); min-width: 0; }
  .result-count { font-size: 0.85rem; color: var(--color-ink-soft); font-variant-numeric: tabular-nums; white-space: nowrap; }

  .filter-row { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: flex-start; }
  .filter-group { background: #fff; border: 1px solid var(--color-border); border-radius: 0.625rem; min-width: 9rem; }
  .filter-group summary { cursor: pointer; padding: 0.55rem 0.85rem; font-weight: 600; font-size: 0.88rem; color: var(--color-ink); list-style: none; display: flex; gap: 0.4rem; align-items: center; }
  .filter-group summary::-webkit-details-marker { display: none; }
  .filter-group summary::after { content: "▾"; color: var(--color-ink-soft); margin-left: auto; }
  .filter-group[open] summary::after { content: "▴"; }
  .filter-group .active-count { font-size: 0.72rem; background: var(--color-primary); color: #fff; padding: 0.05rem 0.45rem; border-radius: 999px; font-weight: 700; display: none; }
  .filter-group .active-count.has { display: inline; }
  .pill-list { padding: 0.5rem 0.75rem 0.85rem; display: flex; flex-wrap: wrap; gap: 0.4rem; max-height: 18rem; overflow-y: auto; }
  .filter-brand .brand-search { width: calc(100% - 1.5rem); margin: 0 0.75rem 0.5rem; padding: 0.4rem 0.6rem; border: 1px solid var(--color-border); border-radius: 0.45rem; font-size: 0.85rem; }
  .filter-brand .brand-list { padding: 0 0.75rem 0.85rem; display: flex; flex-wrap: wrap; gap: 0.35rem; max-height: 22rem; overflow-y: auto; }

  .pill { cursor: pointer; user-select: none; }
  .pill input { position: absolute; opacity: 0; pointer-events: none; }
  .pill-label { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.3rem 0.65rem; background: var(--color-bg-soft, #f8f6ee); border: 1px solid var(--color-border); border-radius: 999px; font-size: 0.8rem; color: var(--color-ink); transition: background 150ms ease, border-color 150ms ease; }
  .pill input:checked + .pill-label { background: var(--pill-bg, var(--color-primary)); color: #fff; border-color: transparent; }
  .pill input:focus-visible + .pill-label { outline: 2px solid var(--color-primary); outline-offset: 2px; }
  .pill-count { font-size: 0.68rem; opacity: 0.75; font-variant-numeric: tabular-nums; }

  .reset-btn { padding: 0.55rem 0.95rem; background: transparent; border: 1px solid var(--color-border); color: var(--color-ink-soft); border-radius: 0.625rem; cursor: pointer; font-size: 0.85rem; font-weight: 600; transition: color 150ms ease, border-color 150ms ease; align-self: stretch; }
  .reset-btn:hover { color: var(--color-alert); border-color: var(--color-alert); }
  .reset-btn[hidden] { display: none; }

  .catalog-section { margin: 1.5rem 0 2.5rem; }
  .catalog-grid { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr)); gap: 0.45rem; }
  .cat-card { display: contents; }
  .cat-card a { display: flex; align-items: center; gap: 0.7rem; padding: 0.6rem 0.85rem; background: #fff; border: 1px solid var(--color-border); border-radius: 0.625rem; text-decoration: none; color: inherit; transition: border-color 200ms ease, transform 200ms var(--ease-out-expo); content-visibility: auto; contain-intrinsic-size: 0 56px; }
  .cat-card a:hover { border-color: var(--color-primary); transform: translateY(-1px); }
  .cat-card[hidden] { display: none; }
  .c-grade { flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 0.4rem; color: #fff; font-family: var(--font-display); font-weight: 800; font-size: 0.95rem; }
  .c-score { flex-shrink: 0; min-width: 2rem; text-align: center; font-family: var(--font-display); font-weight: 700; color: var(--color-ink-soft); font-variant-numeric: tabular-nums; font-size: 0.85rem; }
  .c-meta { display: flex; flex-direction: column; min-width: 0; }
  .c-brand { font-size: 0.66rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-ink-soft); }
  .c-name { font-size: 0.86rem; color: var(--color-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .empty-state { text-align: center; padding: 2.5rem 1rem; color: var(--color-ink-soft); font-size: 0.95rem; background: var(--color-bg-soft); border-radius: 0.875rem; margin: 1.5rem 0; }
  .link-button { background: 0; border: 0; color: var(--color-primary-dark); cursor: pointer; text-decoration: underline; padding: 0; font: inherit; }

  .catalog-footnote { margin: 1.5rem 0 0; font-size: 0.85rem; color: var(--color-ink-soft); text-align: center; }
  .catalog-footnote a { color: var(--color-primary-dark); }

  .browse-section { margin: 2.5rem 0 0; padding: 1.5rem; background: var(--color-bg-soft); border-radius: 0.875rem; }
  .section-title { font-family: var(--font-display); font-size: 1.2rem; color: var(--color-primary-dark); margin: 0 0 0.5rem; }
  .section-lede { color: var(--color-ink-soft); font-size: 0.9rem; margin: 0 0 1rem; }
  .quick-links { display: flex; gap: 0.75rem; flex-wrap: wrap; margin: 0; }
  .btn-secondary { display: inline-block; padding: 0.55rem 1rem; background: #fff; border: 1px solid var(--color-primary); color: var(--color-primary-dark); border-radius: 0.625rem; text-decoration: none; font-weight: 600; font-size: 0.88rem; }
  .btn-secondary:hover { background: var(--color-primary); color: #fff; }

  @media (max-width: 640px) {
    .filter-group { flex: 1 1 calc(50% - 0.25rem); min-width: 0; }
    .reset-btn { flex: 1 1 100%; }
    .filters { position: static; }
  }
</style>

<script is:inline>
  (function() {
    var grid = document.getElementById("catalog-grid");
    if (!grid) return;
    var cards = Array.prototype.slice.call(grid.querySelectorAll(".cat-card"));
    var totalCount = cards.length;
    var search = document.getElementById("catalog-search");
    var brandSearch = document.getElementById("brand-search");
    var resultCount = document.getElementById("result-count");
    var emptyState = document.getElementById("empty-state");
    var resetBtn = document.getElementById("reset-filters");
    var checkboxes = document.querySelectorAll(".filters input[type=checkbox]");

    var state = { grade: new Set(), category: new Set(), age: new Set(), brand: new Set(), q: "" };

    function applyFilters() {
      var q = state.q.trim().toLowerCase();
      var visible = 0;
      for (var i = 0; i < cards.length; i++) {
        var card = cards[i];
        var ok = true;
        if (state.grade.size && !state.grade.has(card.dataset.grade)) ok = false;
        if (ok && state.category.size && !state.category.has(card.dataset.category)) ok = false;
        if (ok && state.brand.size && !state.brand.has(card.dataset.brand)) ok = false;
        if (ok && state.age.size && !state.age.has(card.dataset.age)) ok = false;
        if (ok && q && card.dataset.search.indexOf(q) === -1) ok = false;
        card.hidden = !ok;
        if (ok) visible++;
      }
      resultCount.textContent = visible + " produit" + (visible !== 1 ? "s" : "") +
        (visible !== totalCount ? " sur " + totalCount : "");
      emptyState.hidden = visible !== 0;
      var hasActive = state.grade.size + state.category.size + state.brand.size + state.age.size > 0 || q.length > 0;
      resetBtn.hidden = !hasActive;
      updateActiveCounts();
    }

    function updateActiveCounts() {
      ["grade", "category", "age", "brand"].forEach(function(name) {
        var span = document.querySelector('[data-filter-active="' + name + '"]');
        if (!span) return;
        var n = state[name].size;
        if (n) { span.textContent = n; span.classList.add("has"); }
        else { span.textContent = ""; span.classList.remove("has"); }
      });
    }

    checkboxes.forEach(function(cb) {
      cb.addEventListener("change", function() {
        var set = state[cb.name];
        if (cb.checked) set.add(cb.value); else set.delete(cb.value);
        applyFilters();
      });
    });

    var debounceTimer;
    if (search) {
      search.addEventListener("input", function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function() {
          state.q = search.value;
          applyFilters();
        }, 80);
      });
    }

    if (brandSearch) {
      brandSearch.addEventListener("input", function() {
        var q = brandSearch.value.trim().toLowerCase();
        var pills = document.querySelectorAll(".brand-pill");
        for (var i = 0; i < pills.length; i++) {
          var name = pills[i].getAttribute("data-brand-name") || "";
          pills[i].hidden = q && name.indexOf(q) === -1;
        }
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener("click", function() {
        ["grade", "category", "age", "brand"].forEach(function(k) { state[k].clear(); });
        state.q = "";
        if (search) search.value = "";
        if (brandSearch) brandSearch.value = "";
        checkboxes.forEach(function(cb) { cb.checked = false; });
        document.querySelectorAll(".brand-pill[hidden]").forEach(function(p) { p.hidden = false; });
        applyFilters();
      });
    }

    // Sync filters from URL hash : /products/#grade=A,B&category=petits-pots
    function readFromHash() {
      var hash = location.hash.replace(/^#/, "");
      if (!hash) return;
      var pairs = hash.split("&");
      pairs.forEach(function(pair) {
        var kv = pair.split("=");
        if (kv.length !== 2) return;
        var key = kv[0];
        var values = decodeURIComponent(kv[1]).split(",").filter(Boolean);
        if (key === "q") {
          state.q = values.join(",");
          if (search) search.value = state.q;
        } else if (state[key]) {
          values.forEach(function(v) {
            state[key].add(v);
            var cb = document.querySelector('input[name="' + key + '"][value="' + v + '"]');
            if (cb) cb.checked = true;
          });
        }
      });
      applyFilters();
    }

    readFromHash();
    window.addEventListener("hashchange", readFromHash);
  })();
</script>
