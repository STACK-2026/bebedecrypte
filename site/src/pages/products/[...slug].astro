---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "../../../site.config";
import { AUTHORS, DEFAULT_REVIEWER_NOTE } from "../../data/authors";
import recallsIndex from "../../data/recalls_index.json";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((p) => ({ params: { slug: p.data.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await render(product);

// RappelConso match : if this product's barcode is in the DGCCRF index,
// we surface a red banner above everything else and add the recall to JSON-LD.
const recallHit: { numeroFiche: string; title: string; publishedDate: string; severity: string; status: string; motif: string } | null =
  data.barcode && (recallsIndex as any)[data.barcode] ? (recallsIndex as any)[data.barcode] : null;

// Reviewer Person (resolved from authors registry, not just a free-text string)
function findReviewerSlug(name: string | undefined): string | undefined {
  if (!name) return undefined;
  const head = name.split(",")[0].trim().toLowerCase();
  const match = AUTHORS.find((a) => head.includes(a.name.toLowerCase().replace(/^dr\.\s*/, "")));
  return match?.slug;
}
const reviewerName = data.reviewedBy ? data.reviewedBy.split(",")[0].trim() : "BébéDécrypte Editorial";
const reviewerSlug = findReviewerSlug(data.reviewedBy);
const reviewer = reviewerSlug ? AUTHORS.find((a) => a.slug === reviewerSlug) : undefined;
const reviewerUrl = reviewer ? `${siteConfig.url}/authors/${reviewer.slug}/` : `${siteConfig.url}/authors/`;
const reviewerPerson = {
  "@type": "Person",
  "@id": reviewerUrl + "#person",
  name: reviewerName,
  url: reviewerUrl,
  ...(reviewer
    ? {
        jobTitle: reviewer.role.fr,
        knowsAbout: reviewer.specialities.fr,
      }
    : {}),
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "Catalogue", item: siteConfig.url + "/products/" },
    // (Breadcrumb item 3 = brand, item 4 = product)
    { "@type": "ListItem", position: 3, name: data.brand, item: `${siteConfig.url}/brands/${data.brandSlug}/` },
    { "@type": "ListItem", position: 4, name: data.name },
  ],
};

const productUrl = `${siteConfig.url}/products/${data.slug}/`;
const reviewDateObj = (data.lastReviewed || data.publishedDate || new Date()) as Date;
const reviewDate = reviewDateObj instanceof Date && !Number.isNaN(reviewDateObj.valueOf())
  ? reviewDateObj.toISOString().split("T")[0]
  : "2026-04-22";

// Best-effort age mapping (months to PeopleAudience suggestedMinAge)
const audienceMinAge = data.targetAgeMonths && data.targetAgeMonths > 0 ? data.targetAgeMonths / 12 : undefined;

// Additive intel : surface ANSES/EFSA reasoning for the most-cited problem
// ingredients. These strings are kept short and quotable, the source is stable
// (regulator) and the data-claim attribute makes them addressable by LLMs.
const ADDITIVE_INTEL: Record<string, { label: string; risk: string; source: string; sourceUrl: string }> = {
  E150d: {
    label: "Caramel au sulfite d'ammonium",
    risk: "Colorant à éviter chez le nourrisson : la JECFA / EFSA a fixé une DJA stricte de 200 mg/kg et l'additif n'a aucun intérêt nutritionnel.",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/topics/topic/food-additives",
  },
  E306: {
    label: "Tocophérols (vitamine E naturelle)",
    risk: "Antioxydant naturel toléré dans l'alimentation infantile. N'est pas un signal négatif fort, mais marque une recette transformée.",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/topics/topic/food-additives",
  },
  E322: {
    label: "Lécithines (souvent de tournesol ou soja)",
    risk: "Émulsifiant autorisé en bio (E322i = soja, vérifier l'allergène). À éviter chez l'enfant allergique au soja sans précision sur l'origine.",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/topics/topic/food-additives",
  },
  E330: {
    label: "Acide citrique",
    risk: "Toléré par l'EFSA mais marqueur d'ultra-transformation : n'a rien à faire dans une recette d'aliment infantile peu transformée.",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/topics/topic/food-additives",
  },
  E331: {
    label: "Citrates de sodium",
    risk: "Régulateur d'acidité autorisé dans les aliments infantiles. Marqueur de produit transformé, pas de risque toxicologique au DJA fixée par l'EFSA.",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/topics/topic/food-additives",
  },
  E336: {
    label: "Tartrates de potassium",
    risk: "Régulateur d'acidité toléré, mais l'ANSES recommande de limiter tous les additifs avant 3 ans même autorisés.",
    source: "ANSES",
    sourceUrl: "https://www.anses.fr/fr/content/alimentation-des-enfants-de-moins-de-3-ans",
  },
  E343: {
    label: "Phosphates de magnésium",
    risk: "Source de phosphates ajoutés. Une consommation excessive de phosphates est associée à des effets osseux et rénaux chez l'enfant (avis EFSA 2019).",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/news/phosphates-update-safety-following-evaluation-food-additives",
  },
  E471: {
    label: "Mono- et diglycérides d'acides gras",
    risk: "Émulsifiant ultra-transformé, à limiter dans l'alimentation des moins de 3 ans selon l'avis ANSES sur l'alimentation infantile.",
    source: "ANSES",
    sourceUrl: "https://www.anses.fr/fr/content/alimentation-des-enfants-de-moins-de-3-ans",
  },
  E500: {
    label: "Carbonates de sodium",
    risk: "Poudre levante très utilisée en biscuiterie. Toléré par l'EFSA, mais signe d'un produit ultra-transformé NOVA 4.",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/topics/topic/food-additives",
  },
  E503: {
    label: "Carbonates d'ammonium",
    risk: "Poudre à lever toléré par l'EFSA. Marqueur d'ultra-transformation, sans risque toxicologique aux DJA prévues.",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/topics/topic/food-additives",
  },
  E585: {
    label: "Lactate ferreux",
    risk: "Apport de fer, autorisé en alimentation infantile. Pas un signal négatif sauf dans les recettes non enrichies en fer.",
    source: "EFSA",
    sourceUrl: "https://www.efsa.europa.eu/en/topics/topic/food-additives",
  },
  Maltodextrine: {
    label: "Maltodextrine",
    risk: "Sucre caché à index glycémique très élevé (jusqu'à 105). L'OMS recommande zéro sucre ajouté avant 12 mois et la maltodextrine compte comme tel.",
    source: "OMS",
    sourceUrl: "https://www.who.int/publications/i/item/9789240081864",
  },
  "Sirop de glucose": {
    label: "Sirop de glucose",
    risk: "Sucre rapide à éviter avant 3 ans (recommandation ANSES sur les sucres ajoutés en alimentation infantile).",
    source: "ANSES",
    sourceUrl: "https://www.anses.fr/fr/content/le-sucre-une-place-limitee-dans-lalimentation",
  },
  Miel: {
    label: "Miel",
    risk: "L'ANSES rappelle que le miel est strictement contre-indiqué avant 12 mois (risque de botulisme infantile, rare mais grave).",
    source: "ANSES",
    sourceUrl: "https://www.anses.fr/fr/content/botulisme-infantile",
  },
  "Jus de fruit concentré": {
    label: "Jus de fruit concentré",
    risk: "Sucre concentré (équivalent en glycémie au sucre raffiné). Comptabilisé comme sucre ajouté dans la pondération bébé.",
    source: "OMS",
    sourceUrl: "https://www.who.int/publications/i/item/9789240081864",
  },
};

// Normalize an additive code coming from Open Food Facts ("en:e471", "en:e336i")
// down to the canonical key in ADDITIVE_INTEL ("E471", "E336").
function normalizeAdditive(raw: string): string {
  let code = raw.replace(/^en:/i, "").trim();
  const m = code.match(/^e(\d{3,4})([a-z]*)$/i);
  if (m) {
    // Keep variant only if it's a known distinct entry (e.g. E150d).
    const full = "E" + m[1] + (m[2] || "");
    if (ADDITIVE_INTEL[full]) return full;
    return "E" + m[1];
  }
  return code;
}

function intelFor(code: string) {
  const norm = normalizeAdditive(code);
  if (ADDITIVE_INTEL[norm]) return ADDITIVE_INTEL[norm];
  if (/maltodextrine/i.test(code)) return ADDITIVE_INTEL["Maltodextrine"];
  if (/sirop.*glucose/i.test(code)) return ADDITIVE_INTEL["Sirop de glucose"];
  if (/\bmiel\b/i.test(code)) return ADDITIVE_INTEL["Miel"];
  if (/jus.*concentr/i.test(code)) return ADDITIVE_INTEL["Jus de fruit concentré"];
  return undefined;
}

// Detect hidden sugars in the raw ingredient list (OFF stores them as text,
// not as additives), so the citable section catches them too.
const ingredientTokens: string[] = [];
const ing = (data.ingredients || "").toLowerCase();
if (/maltodextrine/.test(ing)) ingredientTokens.push("Maltodextrine");
if (/sirop\s+de\s+glucose/.test(ing)) ingredientTokens.push("Sirop de glucose");
if (/\bmiel\b/.test(ing) && (data.targetAgeMonths || 999) < 12) ingredientTokens.push("Miel");
if (/jus.*concentr/.test(ing)) ingredientTokens.push("Jus de fruit concentré");

const flaggedAdditives = [
  ...(data.additives || []).map((code: string) => ({
    code: normalizeAdditive(code),
    intel: intelFor(code),
  })),
  ...ingredientTokens.map((token) => ({ code: token, intel: intelFor(token) })),
]
  .filter((x: any) => x.intel)
  // Dedupe by code (some products have e336 + e336i which both fold to E336).
  .filter((x: any, i: number, arr: any[]) => arr.findIndex((y: any) => y.code === x.code) === i);

// FAQ : 3 Q standardisées par fiche, basées sur les data du produit.
// Hébergées en JSON-LD FAQPage + rendues visiblement.
const ageAnswer = data.ageRange
  ? `Le fabricant indique une consommation à partir de ${data.ageRange}. BébéDécrypte rappelle que pour tout produit destiné aux moins de 12 mois, la pondération est renforcée sur les additifs et les sucres cachés (l'OMS recommande zéro sucre ajouté avant 1 an).`
  : `L'étiquette ne précise pas un âge unique. BébéDécrypte applique systématiquement une pondération renforcée sur les additifs et les sucres cachés pour les produits potentiellement consommés avant 3 ans.`;
const isOrganic = (data.categories || []).some((c: string) => /bio|biologique|organic/i.test(c)) ||
  /\bbio\b|biologique|organic/i.test(data.brand + " " + data.name);
const bioAnswer = isOrganic
  ? `Oui, ${data.brand} ${data.name} porte une mention bio (UE / AB / Demeter selon la marque). Le bio pèse 10 % dans la note finale BébéDécrypte ; il limite mais n'élimine pas les additifs autorisés en bio (E322, E330, E331).`
  : `Non, ${data.brand} ${data.name} n'est pas certifié bio dans nos données Open Food Facts. Tu peux filtrer le catalogue sur la catégorie « bio » via /categories/.`;
const alternativesUrl = `/categories/${data.catalogCategory}/`;
const altAnswer = `Pour des alternatives mieux notées dans la même catégorie, regarde la page /categories/${data.catalogCategory}/ : les produits sont triés par score décroissant, on y voit immédiatement quelles marques font A ou B sur le même type de recette.`;
const additiveSummary = flaggedAdditives.length > 0
  ? `${flaggedAdditives.length} additif${flaggedAdditives.length > 1 ? "s" : ""} ou sucre${flaggedAdditives.length > 1 ? "s" : ""} caché${flaggedAdditives.length > 1 ? "s" : ""} a été détecté : ${flaggedAdditives.map((x: any) => x.code).join(", ")}. Voir la section « Selon nos sources » plus bas pour le détail EFSA / ANSES.`
  : `Aucun additif ni sucre caché problématique n'a été détecté dans la liste d'ingrédients référencée par Open Food Facts pour ce produit.`;

const productFaq = [
  {
    question: `À partir de quel âge ${data.brand} ${data.name} convient-il ?`,
    answer: ageAnswer,
  },
  {
    question: `${data.brand} ${data.name} est-il bio ?`,
    answer: bioAnswer,
  },
  {
    question: `Quels additifs ou sucres cachés contient ${data.name} ?`,
    answer: additiveSummary,
  },
  {
    question: `Quelles alternatives mieux notées dans la catégorie ${data.catalogCategory} ?`,
    answer: altAnswer,
  },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: productFaq.map((q) => ({
    "@type": "Question",
    name: q.question,
    acceptedAnswer: { "@type": "Answer", text: q.answer },
  })),
};

const productLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": productUrl + "#product",
  name: `${data.brand} ${data.name}`,
  url: productUrl,
  brand: {
    "@type": "Brand",
    name: data.brand,
    url: `${siteConfig.url}/brands/${data.brandSlug}/`,
  },
  description: data.description,
  ...(data.image ? { image: data.image } : {}),
  ...(data.barcode
    ? {
        gtin: data.barcode,
        gtin13: data.barcode,
        sku: data.barcode,
        productID: `ean:${data.barcode}`,
        identifier: { "@type": "PropertyValue", propertyID: "EAN", value: data.barcode },
      }
    : {}),
  category: data.catalogCategory,
  additionalType: "https://schema.org/FoodProduct",
  ...(audienceMinAge !== undefined
    ? {
        audience: {
          "@type": "PeopleAudience",
          suggestedMinAge: audienceMinAge,
          audienceType: "Infant",
        },
      }
    : {}),
  ...(data.nutriScore
    ? { additionalProperty: { "@type": "PropertyValue", name: "Nutri-Score", value: String(data.nutriScore).toUpperCase() } }
    : {}),
  // aggregateRating mirrors our single editorial review : Google requires
  // either offers OR aggregateRating to surface a Product rich result.
  // BébéDécrypte is a rating service, not an e-commerce site, so we expose
  // the editorial score (0-100) as both a single Review and the aggregate.
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: data.score,
    bestRating: 100,
    worstRating: 0,
    ratingCount: 1,
    reviewCount: 1,
  },
  // reviewedBy at Product level (in addition to review.author below) increases
  // expert-author signal for Google Search and AI engines.
  reviewedBy: reviewerPerson,
  review: {
    "@type": "Review",
    name: `Analyse BébéDécrypte ${data.brand} ${data.name}`,
    author: reviewerPerson,
    publisher: {
      "@type": "Organization",
      name: "BébéDécrypte",
      url: siteConfig.url,
    },
    reviewRating: {
      "@type": "Rating",
      ratingValue: data.score,
      bestRating: 100,
      worstRating: 0,
      alternateName: data.grade,
    },
    reviewBody: data.description,
    datePublished: reviewDate,
  },
};

const gradeColors: Record<string, string> = { A: "var(--grade-a)", B: "var(--grade-b)", C: "var(--grade-c)", D: "var(--grade-d)", E: "var(--grade-e)" };

// SpecialAnnouncement schema for the recall banner (Google rich result for safety alerts).
const recallAnnouncement = recallHit ? {
  "@context": "https://schema.org",
  "@type": "SpecialAnnouncement",
  "@id": productUrl + "#recall-announcement",
  name: recallHit.title,
  text: recallHit.motif,
  datePosted: recallHit.publishedDate + "T00:00:00+00:00",
  category: "https://www.wikidata.org/wiki/Q1153628",
  url: `${siteConfig.url}/rappels/${recallHit.numeroFiche}/`,
  inLanguage: "fr-FR",
  spatialCoverage: { "@type": "Country", name: "France" },
  publisher: { "@id": `${siteConfig.url}/#organization` },
} : null;

const productPageJsonLd = recallAnnouncement
  ? [productLd, breadcrumb, faqLd, recallAnnouncement]
  : [productLd, breadcrumb, faqLd];

const recallTitlePrefix = recallHit && recallHit.status === "active"
  ? "[RAPPEL EN COURS] "
  : "";
const finalTitle = recallTitlePrefix + data.title;
---

<BaseLayout title={finalTitle} description={data.description} jsonLd={productPageJsonLd} localized={false}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://images.openfoodfacts.org" crossorigin />
  </Fragment>
  <article class="product-page">
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> <span aria-hidden="true">·</span>
      <a href="/products/">Catalogue</a> <span aria-hidden="true">·</span>
      <a href={`/brands/${data.brandSlug}/`}>{data.brand}</a> <span aria-hidden="true">·</span>
      <span>{data.name}</span>
    </nav>

    {recallHit && (
      <aside class={`recall-banner ${recallHit.status === "active" ? "active" : "ended"}`} role="alert" data-speakable>
        <div class="rb-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 4h.01M5 21h14a2 2 0 001.79-2.89l-7-12a2 2 0 00-3.58 0l-7 12A2 2 0 005 21z"/></svg>
        </div>
        <div class="rb-text">
          <p class="rb-title">
            {recallHit.status === "active" ? "Rappel produit en cours (DGCCRF)" : "Ce produit a fait l'objet d'un rappel (DGCCRF)"}
          </p>
          <p class="rb-motif">{recallHit.motif}</p>
          <p class="rb-meta">
            Publié le {new Date(recallHit.publishedDate).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })} · Réf. {recallHit.numeroFiche}
          </p>
          <p class="rb-cta">
            <a href={`/rappels/${recallHit.numeroFiche}/`} class="rb-link">Voir la fiche rappel complète →</a>
          </p>
        </div>
      </aside>
    )}

    <header class="p-header fade-up">
      <div class="p-grade-wrapper">
        <div class="p-grade" style={`background: ${gradeColors[data.grade] || "#0891b2"};`} aria-label={`Note ${data.grade}`}>
          <span class="p-grade-letter">{data.grade}</span>
          <span class="p-grade-score">{data.score}/100</span>
        </div>
      </div>
      <div class="p-title">
        <p class="p-brand"><a href={`/brands/${data.brandSlug}/`}>{data.brand}</a></p>
        <h1 data-speakable>{data.name}</h1>
        <p class="p-meta" data-speakable>Note BébéDécrypte : {data.grade} ({data.score}/100). {data.ageRange ? `Tranche d'âge : ${data.ageRange}.` : ""}</p>
        <p class="p-reviewer-badge">
          <span aria-hidden="true">✍</span>
          Relu par <a href={reviewerUrl}>{reviewerName}</a>{reviewer ? ` · ${reviewer.role.fr}` : ""}
        </p>
      </div>
      {data.image && (
        <figure class="p-image">
          <img src={data.image} alt={data.imageAlt || `${data.brand} ${data.name}`} loading="lazy" width="260" height="260" />
        </figure>
      )}
    </header>

    {data.warnings && data.warnings.length > 0 && (
      <aside class="p-warnings fade-up" role="alert" data-speakable>
        <p class="p-warnings-label">⚠ Points d'attention</p>
        <ul>{data.warnings.map((w: string) => <li>{w}</li>)}</ul>
      </aside>
    )}

    <section class="p-body fade-up">
      <Content />
    </section>

    {flaggedAdditives.length > 0 && (
      <section class="p-citable fade-up" aria-labelledby="selon-nos-sources">
        <h2 id="selon-nos-sources">Selon nos sources réglementaires</h2>
        <p class="p-citable-lede">Pour chaque additif ou sucre caché signalé, voici la position des autorités sanitaires citées dans notre méthodologie.</p>
        <ul class="p-citable-list">
          {flaggedAdditives.map((x: any) => (
            <li class="citable-item" data-claim-source={x.intel.source}>
              <p class="citable-code"><strong>{x.code}</strong> · {x.intel.label}</p>
              <p class="citable-quote">
                <cite>Selon {x.intel.source} :</cite> {x.intel.risk}
              </p>
              <p class="citable-link"><a href={x.intel.sourceUrl} rel="noopener external" target="_blank">Voir la source {x.intel.source} ↗</a></p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="p-meta-block fade-up">
      <h2>Détails techniques</h2>
      <dl>
        {data.nutriScore && (<><dt>Nutri-Score</dt><dd>{data.nutriScore.toUpperCase()}</dd></>)}
        {data.nova && (<><dt>Classe NOVA</dt><dd>{data.nova} / 4</dd></>)}
        {data.barcode && (<><dt>Code-barres</dt><dd>{data.barcode}</dd></>)}
        {data.additives && data.additives.length > 0 && (<><dt>Additifs détectés</dt><dd>{data.additives.join(", ")}</dd></>)}
        {data.ingredientCount > 0 && (<><dt>Nombre d'ingrédients</dt><dd>{data.ingredientCount}</dd></>)}
      </dl>
    </section>

    <section class="p-faq fade-up" aria-labelledby="questions-frequentes">
      <h2 id="questions-frequentes">Questions fréquentes</h2>
      <dl class="faq-list">
        {productFaq.map((q) => (
          <>
            <dt class="faq-q" data-speakable>{q.question}</dt>
            <dd class="faq-a" data-speakable>{q.answer}</dd>
          </>
        ))}
      </dl>
      <p class="faq-link"><a href={alternativesUrl}>Voir les meilleures alternatives dans cette catégorie &rarr;</a></p>
    </section>

    <section class="p-sources fade-up">
      <h2>Sources</h2>
      <ul>
        {(data.sources || []).map((s: string) => <li>{s}</li>)}
        {data.sourceUrl && (<li><a href={data.sourceUrl} rel="noopener external" target="_blank">Voir la fiche Open Food Facts ↗</a></li>)}
      </ul>
      {data.reviewedBy && (
        <p class="p-reviewed">
          Relu le {reviewDate} par <a href={reviewerUrl}>{reviewerName}</a>{reviewer ? `, ${reviewer.role.fr}` : ""}.
          <br /><span class="reviewer-note">{DEFAULT_REVIEWER_NOTE.fr}</span>
        </p>
      )}
    </section>

    <section class="p-cta fade-up">
      <a href={`/brands/${data.brandSlug}/`} class="btn-secondary">Autres produits {data.brand}</a>
      <a href="/products/" class="btn-primary hover-shine">Voir tout le catalogue</a>
    </section>
  </article>
</BaseLayout>

<style>
  .product-page { max-width: 56rem; margin: 2rem auto 4rem; padding: 0 1.25rem; }
  .breadcrumb { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.82rem; color: var(--color-ink-soft); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-primary-dark); text-decoration: underline; text-underline-offset: 3px; }
