---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "../../../site.config";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((p) => ({ params: { slug: p.data.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await render(product);

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "Catalogue", item: siteConfig.url + "/rankings/" },
    { "@type": "ListItem", position: 3, name: data.brand, item: `${siteConfig.url}/brands/${data.brandSlug}/` },
    { "@type": "ListItem", position: 4, name: data.name },
  ],
};

const productLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${data.brand} ${data.name}`,
  brand: { "@type": "Brand", name: data.brand },
  description: data.description,
  ...(data.image ? { image: data.image } : {}),
  ...(data.barcode ? { gtin13: data.barcode } : {}),
  category: data.catalogCategory,
  additionalType: "https://schema.org/FoodProduct",
  review: {
    "@type": "Review",
    author: { "@type": "Organization", name: "BébéDécrypte", url: siteConfig.url },
    reviewRating: {
      "@type": "Rating",
      ratingValue: data.score,
      bestRating: 100,
      worstRating: 0,
      alternateName: data.grade,
    },
    reviewBody: data.description,
    datePublished: data.lastReviewed || data.publishedDate || "2026-04-22",
  },
};

const gradeColors: Record<string, string> = { A: "var(--grade-a)", B: "var(--grade-b)", C: "var(--grade-c)", D: "var(--grade-d)", E: "var(--grade-e)" };
---

<BaseLayout title={data.title} description={data.description} jsonLd={[productLd, breadcrumb]}>
  <article class="product-page">
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> <span aria-hidden="true">·</span>
      <a href="/rankings/">Catalogue</a> <span aria-hidden="true">·</span>
      <a href={`/brands/${data.brandSlug}/`}>{data.brand}</a> <span aria-hidden="true">·</span>
      <span>{data.name}</span>
    </nav>

    <header class="p-header fade-up">
      <div class="p-grade-wrapper">
        <div class="p-grade" style={`background: ${gradeColors[data.grade] || "#0891b2"};`} aria-label={`Note ${data.grade}`}>
          <span class="p-grade-letter">{data.grade}</span>
          <span class="p-grade-score">{data.score}/100</span>
        </div>
      </div>
      <div class="p-title">
        <p class="p-brand"><a href={`/brands/${data.brandSlug}/`}>{data.brand}</a></p>
        <h1 data-speakable>{data.name}</h1>
        <p class="p-meta">{data.ageRange ? `Tranche d'âge : ${data.ageRange}` : ""}</p>
      </div>
      {data.image && (
        <figure class="p-image">
          <img src={data.image} alt={data.imageAlt || `${data.brand} ${data.name}`} loading="lazy" />
        </figure>
      )}
    </header>

    {data.warnings && data.warnings.length > 0 && (
      <aside class="p-warnings fade-up" role="alert">
        <p class="p-warnings-label">⚠ Points d'attention</p>
        <ul>{data.warnings.map((w: string) => <li>{w}</li>)}</ul>
      </aside>
    )}

    <section class="p-body fade-up">
      <Content />
    </section>

    <section class="p-meta-block fade-up">
      <h2>Détails techniques</h2>
      <dl>
        {data.nutriScore && (<><dt>Nutri-Score</dt><dd>{data.nutriScore.toUpperCase()}</dd></>)}
        {data.nova && (<><dt>Classe NOVA</dt><dd>{data.nova} / 4</dd></>)}
        {data.barcode && (<><dt>Code-barres</dt><dd>{data.barcode}</dd></>)}
        {data.additives && data.additives.length > 0 && (<><dt>Additifs détectés</dt><dd>{data.additives.join(", ")}</dd></>)}
        {data.ingredientCount > 0 && (<><dt>Nombre d'ingrédients</dt><dd>{data.ingredientCount}</dd></>)}
      </dl>
    </section>

    <section class="p-sources fade-up">
      <h2>Sources</h2>
      <ul>
        {(data.sources || []).map((s: string) => <li>{s}</li>)}
        {data.sourceUrl && (<li><a href={data.sourceUrl} rel="noopener external" target="_blank">Voir la fiche Open Food Facts ↗</a></li>)}
      </ul>
      {data.reviewedBy && (<p class="p-reviewed">Relu le {data.lastReviewed} par {data.reviewedBy}.</p>)}
    </section>

    <section class="p-cta fade-up">
      <a href={`/brands/${data.brandSlug}/`} class="btn-secondary">Autres produits {data.brand}</a>
      <a href="/rankings/" class="btn-primary hover-shine">Voir le classement complet</a>
    </section>
  </article>
</BaseLayout>

<style>
  .product-page { max-width: 56rem; margin: 2rem auto 4rem; padding: 0 1.25rem; }
  .breadcrumb { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.82rem; color: var(--color-ink-soft); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-primary-dark); text-decoration: underline; text-underline-offset: 3px; }
  .p-header { display: grid; grid-template-columns: auto 1fr; gap: 1.5rem; align-items: start; margin-bottom: 2rem; }
  @media (max-width: 640px) { .p-header { grid-template-columns: 1fr; text-align: center; } }
  .p-grade { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 7rem; height: 7rem; border-radius: 1rem; color: #fff; box-shadow: 0 8px 28px -6px rgb(12 10 9 / 0.25); }
  .p-grade-letter { font-family: var(--font-display); font-weight: 900; font-size: 3rem; line-height: 1; }
  .p-grade-score { font-size: 0.8rem; opacity: 0.85; margin-top: 0.2rem; }
  .p-brand { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary-dark); margin: 0 0 0.4rem; }
  .p-brand a { color: inherit; text-decoration: none; }
  .p-brand a:hover { text-decoration: underline; }
  .p-title h1 { font-size: clamp(1.5rem, 3.5vw, 2.1rem); margin: 0 0 0.5rem; line-height: 1.2; }
  .p-meta { color: var(--color-ink-soft); font-size: 0.92rem; margin: 0; }
  .p-image { grid-column: 1 / -1; margin: 1.5rem 0 0; }
  .p-image img { max-width: 260px; max-height: 260px; border-radius: 0.75rem; background: var(--color-bg-soft); padding: 0.5rem; }
  .p-warnings { background: #fef2f2; border-left: 4px solid var(--color-alert); border-radius: 0 0.75rem 0.75rem 0; padding: 1rem 1.25rem; margin-bottom: 2rem; }
  .p-warnings-label { font-weight: 800; color: var(--color-alert); margin: 0 0 0.5rem; font-size: 0.9rem; }
  .p-warnings ul { margin: 0; padding-left: 1.2rem; color: var(--color-ink); font-size: 0.9rem; }
  .p-body { margin-bottom: 2rem; line-height: 1.75; color: var(--color-ink-soft); }
  .p-body :global(h2) { font-size: 1.25rem; color: var(--color-primary-dark); margin: 1.5rem 0 0.75rem; }
  .p-body :global(ul), .p-body :global(ol) { padding-left: 1.35rem; }
  .p-meta-block, .p-sources { background: #fff; border: 1px solid var(--color-border); border-radius: 0.875rem; padding: 1.25rem 1.4rem; margin-bottom: 1.5rem; }
  .p-meta-block h2, .p-sources h2 { font-size: 1.1rem; color: var(--color-primary-dark); margin: 0 0 0.85rem; }
  .p-meta-block dl { display: grid; grid-template-columns: auto 1fr; gap: 0.4rem 1rem; font-size: 0.9rem; }
  .p-meta-block dt { font-weight: 700; color: var(--color-ink); }
  .p-meta-block dd { margin: 0; color: var(--color-ink-soft); }
  .p-sources ul { padding-left: 1.2rem; font-size: 0.88rem; color: var(--color-ink-soft); }
  .p-sources a { color: var(--color-primary-dark); }
  .p-reviewed { font-size: 0.82rem; color: var(--color-ink-soft); font-style: italic; margin: 0.75rem 0 0; }
  .p-cta { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }
</style>
