---
import BaseLayout from "../layouts/BaseLayout.astro";
import MethodologyPage from "../components/sections/MethodologyPage.astro";
import { siteConfig } from "../../site.config";

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "Méthodologie" },
  ],
};

const webPage = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "@id": `${siteConfig.url}/methodology/#article`,
  headline: "Comment BébéDécrypte note chaque produit bébé , méthodologie 8 axes",
  url: `${siteConfig.url}/methodology/`,
  inLanguage: "fr-FR",
  publisher: { "@id": `${siteConfig.url}/#organization` },
  about: [
    { "@type": "Thing", name: "Classification NOVA" },
    { "@type": "Thing", name: "Base additifs EFSA" },
    { "@type": "Thing", name: "Avis nutrition infantile ANSES" },
    { "@type": "Thing", name: "Nutri-Score" },
    { "@type": "Thing", name: "Recommandations ESPGHAN" },
  ],
  speakable: { "@type": "SpeakableSpecification", cssSelector: ["h1", "h2", "[data-speakable]"] },
};
---

<BaseLayout
  title="Méthodologie , Comment BébéDécrypte note chaque produit | BébéDécrypte"
  description="BébéDécrypte utilise un système déterministe en 8 axes (NOVA, additifs EFSA, sucres ajoutés, Nutri-Score, bio, allergènes, origine, simplicité) pondéré pour la nutrition infantile. Note A à E, pondération plus stricte avant 12 mois. Sources ANSES, EFSA, ESPGHAN, RappelConso."
  jsonLd={[webPage, breadcrumb]}
>
  <MethodologyPage />
</BaseLayout>
