---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";

const recallsCol = await getCollection("recalls");
const recalls = recallsCol
  .map((r) => r.data)
  .sort((a, b) => b.publishedDate.valueOf() - a.publishedDate.valueOf());

const activeCount = recalls.filter((r) => r.status === "active").length;
const totalCount = recalls.length;
const matchedCount = recalls.filter((r) => r.matchedProductSlugs.length > 0).length;
const lastDate = recalls[0]?.publishedDate;

const distinctBrands = new Set(recalls.map((r) => r.brand.toLowerCase())).size;
const sevCount: Record<string, number> = { critical: 0, high: 0, medium: 0, low: 0 };
for (const r of recalls) sevCount[r.severity] = (sevCount[r.severity] || 0) + 1;

const title = `Rappels produits bébé : ${totalCount} alertes RappelConso recensées | BébéDécrypte`;
const description = `Tous les rappels DGCCRF / RappelConso d'aliments pour bébé : ${activeCount} en cours, ${totalCount} au total depuis 2020, ${distinctBrands} marques concernées. Mise à jour quotidienne, source officielle data.economie.gouv.fr.`;

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "Rappels produits", item: siteConfig.url + "/rappels/" },
  ],
};

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Rappels d'aliments pour bébé recensés par BébéDécrypte",
  numberOfItems: recalls.length,
  itemListElement: recalls.slice(0, 50).map((r, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${siteConfig.url}/rappels/${r.numeroFiche}/`,
    name: r.title,
  })),
};

const sevColor: Record<string, string> = {
  critical: "#b91c1c",
  high: "#dc2626",
  medium: "#f97316",
  low: "#eab308",
};
const sevLabel: Record<string, string> = {
  critical: "Critique",
  high: "Élevé",
  medium: "Moyen",
  low: "Faible",
};
---

<BaseLayout title={title} description={description} jsonLd={[breadcrumb, itemList]} localized={false}>
  <article class="rappels-page">
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
      <a href="/">Accueil</a> <span aria-hidden="true">·</span>
      <span>Rappels produits</span>
    </nav>

    <header class="r-hero fade-up">
      <p class="eyebrow">Source officielle DGCCRF</p>
      <h1 data-speakable>Rappels produits bébé : {totalCount} alertes officielles recensées</h1>
      <p class="lede" data-speakable>
        Toutes les alertes RappelConso (DGCCRF, ministère de l'Économie) qui concernent l'alimentation infantile depuis 2020. <strong>{activeCount} rappel{activeCount > 1 ? "s" : ""} en cours</strong>, {distinctBrands} marques concernées, {matchedCount} déjà matché{matchedCount > 1 ? "s" : ""} avec une fiche du catalogue BébéDécrypte. Données rafraîchies depuis <a href="https://rappel.conso.gouv.fr/" rel="noopener external" target="_blank">rappel.conso.gouv.fr</a>.
      </p>
      <ul class="r-stats" aria-label="Répartition par sévérité">
        {(["critical", "high", "medium", "low"] as const).map((s) => (
          sevCount[s] > 0 && (
            <li><span class="sev-pill" style={`background:${sevColor[s]};`}>{sevLabel[s]}</span><strong>{sevCount[s]}</strong></li>
          )
        ))}
      </ul>
    </header>

    <section class="r-filters fade-up" aria-label="Filtres">
      <div class="r-search">
        <label for="recall-search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
          <input id="recall-search" type="search" placeholder="Rechercher une marque, un produit, un risque..." autocomplete="off" />
        </label>
        <span id="recall-count" class="r-count">{totalCount} rappels</span>
      </div>
      <div class="r-toggles">
        <label class="r-toggle"><input type="checkbox" name="r-status" value="active" /><span>En cours uniquement</span></label>
        <label class="r-toggle"><input type="checkbox" name="r-sev" value="critical" /><span>Critique</span></label>
        <label class="r-toggle"><input type="checkbox" name="r-sev" value="high" /><span>Élevé</span></label>
        <label class="r-toggle"><input type="checkbox" name="r-matched" value="1" /><span>Avec fiche BébéDécrypte</span></label>
      </div>
    </section>

    <ol class="r-timeline" id="recall-list">
      {recalls.map((r) => (
        <li
          class={`r-card sev-${r.severity} status-${r.status}`}
          data-status={r.status}
          data-sev={r.severity}
          data-matched={r.matchedProductSlugs.length > 0 ? "1" : "0"}
          data-search={(r.brand + " " + r.productLabel + " " + r.motif + " " + r.risk).toLowerCase()}
        >
          <a href={`/rappels/${r.numeroFiche}/`}>
            <div class="r-card-head">
              <span class="r-sev" style={`background:${sevColor[r.severity]};`} aria-label={`Sévérité ${sevLabel[r.severity]}`}>{sevLabel[r.severity]}</span>
              <time class="r-date" datetime={r.publishedDate.toISOString()}>{r.publishedDate.toLocaleDateString("fr-FR", { day: "numeric", month: "short", year: "numeric" })}</time>
              {r.status === "active" && <span class="r-badge-active" aria-label="Rappel en cours">En cours</span>}
              {r.matchedProductSlugs.length > 0 && <span class="r-badge-matched">Fiche {r.matchedProductSlugs.length === 1 ? "matchée" : `${r.matchedProductSlugs.length} matchées`}</span>}
            </div>
            <h2 class="r-title">{r.title}</h2>
            <p class="r-motif">{r.motif}</p>
            <p class="r-meta">
              <span class="r-brand">{r.brand}</span>
              <span aria-hidden="true">·</span>
              <span class="r-sub">{r.subCategory}</span>
              {r.eans.length > 0 && (
                <>
                  <span aria-hidden="true">·</span>
                  <span class="r-eans">{r.eans.length} EAN{r.eans.length > 1 ? "s" : ""}</span>
                </>
              )}
            </p>
          </a>
        </li>
      ))}
    </ol>

    <p class="r-empty" id="recall-empty" hidden>Aucun rappel ne correspond aux filtres. <button type="button" class="link-button" id="recall-reset">Réinitialiser</button></p>

    <section class="r-source fade-up">
      <h2>Source des données</h2>
      <p>
        Les rappels affichés sont tirés du registre public <a href="https://www.data.gouv.fr/fr/datasets/rappelconso/" rel="noopener external" target="_blank">RappelConso de la DGCCRF</a> (jeu de données <code>rappelconso-v2-gtin-espaces</code>, ministère de l'Économie). Nous filtrons par sous-catégorie « aliments pour bébés » et par mots-clés bébé sur les sous-catégories laits et nutrition. Chaque fiche affiche le lien direct vers la fiche officielle, juridiquement opposable. BébéDécrypte n'est pas l'autorité émettrice du rappel : nous républiculons l'information avec attribution.
      </p>
      <p>
        Tu peux aussi t'abonner au <a href="/rappels/rss.xml">flux RSS dédié rappels bébé</a> pour être alerté à chaque nouvelle alerte.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .rappels-page { max-width: 60rem; margin: 2rem auto 4rem; padding: 0 1.25rem; }
  .breadcrumb { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.82rem; color: var(--color-ink-soft); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-primary-dark); text-decoration: underline; text-underline-offset: 3px; }
  .r-hero { margin-bottom: 1.5rem; }
  .eyebrow { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-alert); margin: 0 0 0.5rem; }
  .r-hero h1 { font-size: clamp(1.6rem, 4vw, 2.25rem); margin: 0 0 0.75rem; line-height: 1.2; }
  .lede { color: var(--color-ink-soft); line-height: 1.6; max-width: 50rem; margin: 0 0 1rem; }
  .lede strong { color: var(--color-alert); }
  .r-stats { display: flex; flex-wrap: wrap; gap: 0.6rem; padding: 0; margin: 0; list-style: none; }
  .r-stats li { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.86rem; color: var(--color-ink-soft); background: #fff; border: 1px solid var(--color-border); padding: 0.3rem 0.7rem; border-radius: 999px; }
  .sev-pill { display: inline-flex; align-items: center; justify-content: center; padding: 0.15rem 0.55rem; border-radius: 0.4rem; color: #fff; font-weight: 700; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; }

  .r-filters { background: var(--color-bg-soft); border-radius: 0.875rem; padding: 1rem 1.25rem; border: 1px solid var(--color-border); margin: 1.5rem 0; position: sticky; top: 0.5rem; z-index: 5; }
  .r-search { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .r-search label { display: flex; align-items: center; gap: 0.5rem; flex: 1 1 22rem; padding: 0.55rem 0.85rem; background: #fff; border: 1.5px solid var(--color-border); border-radius: 0.625rem; }
  .r-search label svg { color: var(--color-ink-soft); flex-shrink: 0; }
  .r-search input { flex: 1; border: 0; outline: 0; font-size: 0.95rem; background: transparent; min-width: 0; }
  .r-count { font-size: 0.85rem; color: var(--color-ink-soft); white-space: nowrap; font-variant-numeric: tabular-nums; }
  .r-toggles { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.75rem; }
  .r-toggle { cursor: pointer; user-select: none; }
  .r-toggle input { position: absolute; opacity: 0; pointer-events: none; }
  .r-toggle span { display: inline-flex; padding: 0.3rem 0.65rem; background: #fff; border: 1px solid var(--color-border); border-radius: 999px; font-size: 0.8rem; color: var(--color-ink); transition: background 150ms ease, border-color 150ms ease; }
  .r-toggle input:checked + span { background: var(--color-primary); color: #fff; border-color: transparent; }

  .r-timeline { list-style: none; padding: 0; margin: 1.5rem 0 0; display: flex; flex-direction: column; gap: 0.85rem; }
  .r-card { background: #fff; border: 1px solid var(--color-border); border-radius: 0.875rem; transition: border-color 200ms ease, transform 200ms var(--ease-out-expo); content-visibility: auto; contain-intrinsic-size: 0 160px; }
  .r-card:hover { border-color: var(--color-primary); transform: translateY(-1px); }
  .r-card[hidden] { display: none; }
  .r-card.sev-critical { border-left: 4px solid #b91c1c; }
  .r-card.sev-high { border-left: 4px solid #dc2626; }
  .r-card.sev-medium { border-left: 4px solid #f97316; }
  .r-card.sev-low { border-left: 4px solid #eab308; }
  .r-card a { display: block; padding: 1rem 1.2rem; text-decoration: none; color: inherit; }
  .r-card-head { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.4rem; font-size: 0.78rem; }
  .r-sev { color: #fff; padding: 0.15rem 0.55rem; border-radius: 0.4rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .r-date { color: var(--color-ink-soft); font-variant-numeric: tabular-nums; }
  .r-badge-active { background: #fef2f2; color: #b91c1c; padding: 0.15rem 0.5rem; border-radius: 999px; font-weight: 700; font-size: 0.7rem; }
  .r-badge-matched { background: #ecfeff; color: #0e7490; padding: 0.15rem 0.5rem; border-radius: 999px; font-weight: 600; font-size: 0.7rem; }
  .r-title { font-size: 1.05rem; color: var(--color-ink); margin: 0 0 0.4rem; }
  .r-motif { color: var(--color-ink-soft); margin: 0 0 0.4rem; font-size: 0.92rem; line-height: 1.5; }
  .r-meta { font-size: 0.78rem; color: var(--color-ink-soft); margin: 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .r-brand { font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-primary-dark); }

  .r-empty { text-align: center; padding: 2rem; color: var(--color-ink-soft); background: var(--color-bg-soft); border-radius: 0.875rem; margin: 1.5rem 0; }
  .link-button { background: 0; border: 0; color: var(--color-primary-dark); cursor: pointer; text-decoration: underline; padding: 0; font: inherit; }

  .r-source { margin: 2.5rem 0; padding: 1.5rem; background: var(--color-bg-soft); border-radius: 0.875rem; }
  .r-source h2 { font-size: 1.15rem; color: var(--color-primary-dark); margin: 0 0 0.75rem; }
  .r-source p { color: var(--color-ink-soft); line-height: 1.65; margin: 0 0 0.75rem; }
  .r-source code { background: #fff; padding: 0.1rem 0.35rem; border-radius: 0.25rem; font-size: 0.88em; }
  .r-source a { color: var(--color-primary-dark); }
</style>

<script is:inline>
  (function() {
    var list = document.getElementById("recall-list");
    if (!list) return;
    var cards = Array.prototype.slice.call(list.querySelectorAll(".r-card"));
    var total = cards.length;
    var search = document.getElementById("recall-search");
    var countEl = document.getElementById("recall-count");
    var emptyEl = document.getElementById("recall-empty");
    var resetBtn = document.getElementById("recall-reset");
    var checkboxes = document.querySelectorAll(".r-filters input[type=checkbox]");

    var state = { active: false, sev: new Set(), matched: false, q: "" };

    function apply() {
      var q = state.q.trim().toLowerCase();
      var visible = 0;
      for (var i = 0; i < cards.length; i++) {
        var c = cards[i];
        var ok = true;
        if (state.active && c.dataset.status !== "active") ok = false;
        if (ok && state.sev.size && !state.sev.has(c.dataset.sev)) ok = false;
        if (ok && state.matched && c.dataset.matched !== "1") ok = false;
        if (ok && q && c.dataset.search.indexOf(q) === -1) ok = false;
        c.hidden = !ok;
        if (ok) visible++;
      }
      countEl.textContent = visible + " rappel" + (visible !== 1 ? "s" : "") +
        (visible !== total ? " sur " + total : "");
      emptyEl.hidden = visible !== 0;
    }

    checkboxes.forEach(function(cb) {
      cb.addEventListener("change", function() {
        if (cb.name === "r-status") state.active = cb.checked;
        else if (cb.name === "r-sev") {
          if (cb.checked) state.sev.add(cb.value); else state.sev.delete(cb.value);
        }
        else if (cb.name === "r-matched") state.matched = cb.checked;
        apply();
      });
    });

    var t;
    if (search) search.addEventListener("input", function() {
      clearTimeout(t);
      t = setTimeout(function() { state.q = search.value; apply(); }, 80);
    });

    if (resetBtn) resetBtn.addEventListener("click", function() {
      state = { active: false, sev: new Set(), matched: false, q: "" };
      checkboxes.forEach(function(cb) { cb.checked = false; });
      if (search) search.value = "";
      apply();
    });
  })();
</script>
