---
import BaseLayout from "../layouts/BaseLayout.astro";
import ComingSoonPage from "../components/sections/ComingSoonPage.astro";

const copy = {
  eyebrow: { fr: "Catalogue", en: "Catalog" },
  title: {
    fr: "Le catalogue des 2 300 produits bébé arrive",
    en: "The 2,300 baby food product catalog is loading",
  },
  lede: {
    fr: "On ingère les petits pots, les laits infantiles, les céréales, les gourdes et les biscuits vendus en France depuis Open Food Facts. Chaque produit est noté de A à E sur 8 axes, puis croisé avec le flux RappelConso et les avis ANSES. Pas d'MVP bancal, on veut la base complète avant d'ouvrir.",
    en: "We are ingesting every baby pot, infant formula, cereal, pouch and biscuit sold in France from Open Food Facts. Each product is graded A to E on 8 axes, then cross-checked with the RappelConso recall feed and ANSES opinions. No half-MVP, we want the complete catalog before opening.",
  },
  expect: {
    fr: [
      "Recherche par marque (Blédina, Babybio, Good Goût, Gallia, Popote, Yooji, Comme des papas, Smileat...)",
      "Filtre par âge, par catégorie, par note A à E",
      "Fiche produit avec les 8 sous-scores, les additifs détectés, les alternatives mieux notées",
      "Alerte rappel produit en temps réel (sync RappelConso / DGCCRF)",
    ],
    en: [
      "Brand search (Blédina, Babybio, Good Goût, Gallia, Popote, Yooji, Comme des papas, Smileat...)",
      "Filter by age, by category, by A to E grade",
      "Product page with all 8 sub-scores, detected additives, better-graded alternatives",
      "Real-time recall alerts (RappelConso / DGCCRF sync)",
    ],
  },
  eta: {
    fr: "Ouverture prévue , semaine du 29 avril 2026. Inscris-toi à la newsletter pour être prévenu.",
    en: "Planned opening , week of 29 April 2026. Subscribe to the newsletter to get notified.",
  },
};

const title = "BébéDécrypte catalog , 2,300 baby food products graded A to E";
const description =
  "Complete catalog of baby food products sold in France, graded A to E on 8 axes (NOVA, additives, added sugars, organic, allergens, origin, simplicity, Nutri-Score). Launching soon.";
---

<BaseLayout title={title} description={description}>
  <ComingSoonPage slug="rankings" copy={copy} />
</BaseLayout>
