---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { siteConfig } from "../../../site.config";

export async function getStaticPaths() {
  const cats = await getCollection("categories");
  const products = await getCollection("products");
  return cats.map((c) => ({
    params: { slug: c.data.slug },
    props: {
      category: c,
      products: products.filter((p) => p.data.catalogCategory === c.data.slug).sort((a, z) => z.data.score - a.data.score),
    },
  }));
}

const { category, products } = Astro.props;
const { data } = category;
const { Content: CatBody } = await render(category);

// Distribution des grades pour appuyer le titre/description
const gradeCount: Record<string, number> = { A: 0, B: 0, C: 0, D: 0, E: 0 };
for (const p of products) gradeCount[p.data.grade] = (gradeCount[p.data.grade] || 0) + 1;
const distinctBrands = new Set(products.map((p: any) => p.data.brandSlug)).size;

// CTR-optimised title: catégorie + volume + grade range + brand BébéDécrypte
const optimisedTitle = `${data.title} bébé : ${products.length} produits notés A à E (${distinctBrands} marques) | BébéDécrypte`;
const optimisedDescription = `Comparateur ${data.title.toLowerCase()} pour bébé : ${products.length} produits analysés sur 8 axes (NOVA, additifs EFSA, sucres cachés, bio, allergènes). ${gradeCount.A} note A, ${gradeCount.B} note B, ${distinctBrands} marques. Sources ANSES, EFSA, Open Food Facts.`.slice(0, 200);

// FAQ : 3 standardised questions per category for FAQPage rich result
const topProducts = products.slice(0, 3);
const catFaq = [
  {
    question: `Quels sont les meilleurs ${data.title.toLowerCase()} pour bébé ?`,
    answer: topProducts.length > 0
      ? `Les ${topProducts.length} mieux notés sur ${products.length} analysés : ${topProducts.map((p: any) => `${p.data.brand} ${p.data.name} (${p.data.grade}, ${p.data.score}/100)`).join(" ; ")}.`
      : `Aucun produit n'est encore référencé dans cette catégorie.`,
  },
  {
    question: `Pourquoi seulement ${gradeCount.A} produit${gradeCount.A > 1 ? "s" : ""} note A dans ${data.title.toLowerCase()} ?`,
    answer: `Pour décrocher un A, un produit doit cumuler une recette peu transformée (NOVA 1-2), zéro additif controversé, zéro sucre caché (maltodextrine, sirop de glucose, miel), et idéalement la certification bio. Sur l'industrie ${data.title.toLowerCase()} en France, peu de recettes cochent toutes les cases simultanément.`,
  },
  {
    question: `Comment BébéDécrypte note les ${data.title.toLowerCase()} ?`,
    answer: `Méthodologie 8 axes pondérés : NOVA ultra-transformation (25 %), additifs EFSA (25 %), sucres ajoutés et cachés (20 %), Nutri-Score (10 %), bio (10 %), transparence allergènes (5 %), origine France (3 %), simplicité de recette (2 %). La pondération est doublée sur les additifs pour les produits visant les moins de 12 mois.`,
  },
];
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: catFaq.map((q) => ({
    "@type": "Question",
    name: q.question,
    acceptedAnswer: { "@type": "Answer", text: q.answer },
  })),
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteConfig.url + "/" },
    { "@type": "ListItem", position: 2, name: "Catalogue", item: siteConfig.url + "/products/" },
    { "@type": "ListItem", position: 3, name: data.title },
  ],
};

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: data.title,
  numberOfItems: products.length,
  itemListElement: products.slice(0, 20).map((p: any, i: number) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${siteConfig.url}/products/${p.data.slug}/`,
    name: `${p.data.brand} ${p.data.name}`,
  })),
};
---

<BaseLayout title={optimisedTitle} description={optimisedDescription} jsonLd={[itemList, breadcrumb, faqLd]} localized={false}>
  <article class="category-page">
    <nav class="breadcrumb">
      <a href="/">Accueil</a> <span aria-hidden="true">·</span>
      <a href="/products/">Catalogue</a> <span aria-hidden="true">·</span>
      <span>{data.title}</span>
    </nav>

    <header class="c-header fade-up">
      <p class="eyebrow">Catégorie</p>
      <h1 data-speakable>{data.title}</h1>
      <p class="lede" data-speakable>{data.description}</p>
      <p class="c-count">{products.length} produit(s) dans cette catégorie</p>
    </header>

    <section class="c-body prose fade-up"><CatBody /></section>

    <section class="c-products fade-up">
      <h2>Top produits (triés par note)</h2>
      <ul class="c-products-list">
        {products.slice(0, 50).map((p: any) => (
          <li>
            <a href={`/products/${p.data.slug}/`} class="c-product-card">
              <span class={`grade grade-sm grade-${p.data.grade.toLowerCase()}`}>{p.data.grade}</span>
              <span class="c-product-info">
                <strong>{p.data.brand}</strong> {p.data.name}
              </span>
              <span class="c-product-score">{p.data.score}/100</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="c-faq fade-up" aria-labelledby="cat-faq">
      <h2 id="cat-faq">Questions fréquentes sur les {data.title.toLowerCase()}</h2>
      <dl class="faq-list">
        {catFaq.map((q) => (
          <>
            <dt class="faq-q" data-speakable>{q.question}</dt>
            <dd class="faq-a" data-speakable>{q.answer}</dd>
          </>
        ))}
      </dl>
    </section>
  </article>
</BaseLayout>

<style>
  .category-page { max-width: 60rem; margin: 2rem auto 4rem; padding: 0 1.25rem; }
  .breadcrumb { display: flex; gap: 0.4rem; flex-wrap: wrap; font-size: 0.82rem; color: var(--color-ink-soft); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--color-primary-dark); text-decoration: underline; text-underline-offset: 3px; }
  .c-header { max-width: 44rem; margin: 0 auto 2rem; text-align: center; }
  .eyebrow { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-primary-dark); margin: 0 0 0.5rem; }
  .c-header h1 { font-size: clamp(1.75rem, 4vw, 2.4rem); margin: 0 0 0.75rem; }
  .lede { color: var(--color-ink-soft); font-size: 1.05rem; margin: 0 0 0.5rem; }
  .c-count { font-size: 0.85rem; color: var(--color-ink-soft); font-style: italic; margin: 0; }
  .c-body { margin: 2rem 0; }
  .c-products h2 { font-size: 1.3rem; color: var(--color-primary-dark); margin: 0 0 1rem; }
  .c-products-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem; }
  .c-product-card { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: #fff; border: 1px solid var(--color-border); border-radius: 0.625rem; text-decoration: none; color: inherit; transition: border-color 200ms ease, transform 200ms var(--ease-out-expo); }
  .c-product-card:hover { border-color: var(--color-primary); transform: translateY(-1px); }
  .c-product-info { flex: 1; color: var(--color-ink); }
  .c-product-info strong { color: var(--color-primary-dark); }
  .c-product-score { font-size: 0.82rem; color: var(--color-ink-soft); font-variant-numeric: tabular-nums; }
  .c-faq { background: #fff; border: 1px solid var(--color-border); border-radius: 0.875rem; padding: 1.25rem 1.4rem; margin-top: 2rem; }
  .c-faq h2 { font-size: 1.1rem; color: var(--color-primary-dark); margin: 0 0 0.85rem; }
  .c-faq .faq-list { display: flex; flex-direction: column; gap: 0.85rem; margin: 0; }
  .c-faq .faq-q { font-weight: 700; color: var(--color-ink); font-size: 0.95rem; margin: 0; }
  .c-faq .faq-a { font-size: 0.9rem; color: var(--color-ink-soft); line-height: 1.6; margin: 0.25rem 0 0; }
</style>
