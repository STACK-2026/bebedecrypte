---
import BaseLayout from "../layouts/BaseLayout.astro";
import ComingSoonPage from "../components/sections/ComingSoonPage.astro";

const copy = {
  eyebrow: { fr: "Comparer", en: "Compare" },
  title: {
    fr: "Compare deux produits bébé côte à côte, objectivement",
    en: "Compare two baby food products side by side, objectively",
  },
  lede: {
    fr: "Blédina vs Babybio, Good Goût vs Popote, un petit pot vs sa version bio, un lait 1er âge vs un lait 2e âge. On aligne les 8 axes, les additifs, les sucres cachés, les warnings, et on te dit lequel choisir , sans rond-de-jambe commercial.",
    en: "Blédina vs Babybio, Good Goût vs Popote, a baby pot vs its organic version, first-age vs follow-on formula. We line up all 8 axes, additives, hidden sugars, warnings, and tell you which one to pick , with zero commercial spin.",
  },
  expect: {
    fr: [
      "Sélection de 2 produits depuis le catalogue ou la recherche",
      "Comparaison axe par axe, ingredient par ingredient",
      "Warnings alignés côte à côte (sucre, additifs, huile de palme, NOVA 4...)",
      "Verdict clair avec la différence chiffrée sur 100",
    ],
    en: [
      "Pick any 2 products from the catalog or search",
      "Axis-by-axis, ingredient-by-ingredient diff",
      "Warnings aligned side by side (sugar, additives, palm oil, NOVA 4...)",
      "Clear verdict with the numeric gap on 100",
    ],
  },
  eta: {
    fr: "Ouverture prévue , mi-mai 2026, juste après le catalogue.",
    en: "Planned opening , mid-May 2026, right after the catalog.",
  },
};

const title = "Compare two baby food products side by side | BébéDécrypte";
const description =
  "Compare any two baby food products side by side: Blédina vs Babybio, Good Goût vs Popote. 8 axes, additives, hidden sugars, warnings aligned. Clear verdict with numeric gap.";
---

<BaseLayout title={title} description={description} noIndex={true}>
  <ComingSoonPage slug="compare" copy={copy} />
</BaseLayout>
