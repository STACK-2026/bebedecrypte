---
import { siteConfig } from "../../site.config";
---

<div id="quiz-container" class="bg-white rounded-2xl border border-gray-100 shadow-xl p-6 md:p-10 text-left scale-reveal overflow-hidden relative" role="region" aria-label="Diagnostic nutrition bébé">
  <div class="absolute top-0 left-0 right-0 h-1 gradient-animated" style={`background: linear-gradient(90deg, ${siteConfig.colors.primary}, ${siteConfig.colors.accent}, ${siteConfig.colors.secondary}, ${siteConfig.colors.primary});`}></div>

  <div class="text-center mb-8">
    <span class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-1.5 rounded-full mb-4" style={`background: color-mix(in srgb, ${siteConfig.colors.accent} 12%, transparent); color: ${siteConfig.colors.accent};`}>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35" /></svg>
      Diagnostic express gratuit
    </span>
    <h2 class="text-xl md:text-2xl font-bold" id="quiz-title" style="letter-spacing: -0.03em;">Ton bébé mange-t-il bien ? Diagnostic en 5 questions</h2>
    <p class="text-gray-400 text-sm mt-2" id="quiz-subtitle">5 questions, 1 minute. Zéro inscription, zéro email.</p>
  </div>

  <div id="quiz-question" class="min-h-[260px]" aria-live="polite" aria-atomic="true"></div>

  <div class="mt-6">
    <div class="flex justify-between text-xs text-gray-400 mb-1.5">
      <span id="quiz-progress-text">Question 1/5</span>
      <span id="quiz-score-text"></span>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-1.5" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-label="Progression du diagnostic">
      <div id="quiz-progress-bar" class="h-1.5 rounded-full transition-all duration-700 ease-out" style={`background: linear-gradient(90deg, ${siteConfig.colors.primary}, ${siteConfig.colors.accent}); width: 0%;`}></div>
    </div>
  </div>
</div>

<script>
  type Axis = "vigilance" | "industriel" | "literacy";
  type Option = { text: string; emoji: string; vigilance?: number; industriel?: number; literacy?: number; tag?: string };

  const questions: { q: string; options: Option[]; key: string }[] = [
    {
      key: "age",
      q: "Quel âge a ton bébé ?",
      options: [
        { text: "0 à 3 mois (lait exclusif)", emoji: "👶", tag: "age-0-3" },
        { text: "4 à 5 mois (début diversification)", emoji: "🍼", tag: "age-4-5" },
        { text: "6 à 8 mois (purées et premiers morceaux)", emoji: "🥕", tag: "age-6-8" },
        { text: "9 à 12 mois (textures variées)", emoji: "🍠", tag: "age-9-12" },
        { text: "12 à 24 mois (repas famille adapté)", emoji: "🍝", tag: "age-12-24" },
        { text: "24 mois et plus", emoji: "🧒", tag: "age-24" },
      ],
    },
    {
      key: "industriel",
      q: "Quelle part de son alimentation vient d'aliments industriels (petits pots, gourdes, céréales infantiles) ?",
      options: [
        { text: "Moins de 20% (tout fait maison ou presque)", emoji: "🥘", industriel: 0, vigilance: 3 },
        { text: "Entre 20 et 50%", emoji: "🍲", industriel: 1, vigilance: 2 },
        { text: "Entre 50 et 80%", emoji: "🥫", industriel: 2, vigilance: 1 },
        { text: "Plus de 80% (majoritairement industriel)", emoji: "📦", industriel: 3, vigilance: 0 },
      ],
    },
    {
      key: "literacy",
      q: "As-tu déjà lu en détail la liste d'ingrédients d'un produit bébé acheté ?",
      options: [
        { text: "Jamais, je regarde juste le rayon bébé", emoji: "🙈", literacy: 0 },
        { text: "Rarement, quand un doute me prend", emoji: "👀", literacy: 1 },
        { text: "De temps en temps, surtout sur les nouveaux produits", emoji: "🔍", literacy: 2 },
        { text: "Systématiquement, je décode chaque étiquette", emoji: "🧠", literacy: 3 },
      ],
    },
    {
      key: "type",
      q: "Tu achètes principalement :",
      options: [
        { text: "Marques industrielles généralistes (Blédina, Nestlé)", emoji: "🛒", industriel: 2, vigilance: 1 },
        { text: "Marques bio spécialisées bébé (Babybio, Hipp, Holle)", emoji: "🌱", industriel: 1, vigilance: 2 },
        { text: "MDD supermarché (U Bio, Carrefour Baby)", emoji: "🏷️", industriel: 2, vigilance: 1 },
        { text: "Fait maison à 90%", emoji: "👩‍🍳", industriel: 0, vigilance: 3 },
        { text: "Un mix équilibré de plusieurs sources", emoji: "🔀", industriel: 1, vigilance: 2 },
      ],
    },
    {
      key: "inquietude",
      q: "Ton inquiétude principale actuelle :",
      options: [
        { text: "Les sucres cachés et le goût trop sucré", emoji: "🍬", tag: "sucres" },
        { text: "Les additifs et émulsifiants", emoji: "🧪", tag: "additifs" },
        { text: "Les pesticides et contaminants", emoji: "☣️", tag: "pesticides" },
        { text: "La qualité nutritionnelle réelle", emoji: "🥦", tag: "nutrition" },
        { text: "Les allergènes et l'introduction", emoji: "🥜", tag: "allergenes" },
        { text: "Les rappels produits et la sécurité", emoji: "⚠️", tag: "rappels" },
      ],
    },
  ];

  type Result = {
    id: string;
    emoji: string;
    title: string;
    text: string;
    recommendations: { label: string; href: string; icon: string }[];
    primaryCta: { label: string; href: string };
    color: string;
  };

  const colors = {
    primary: "#0891b2",
    primaryDark: "#155e75",
    accent: "#f59e0b",
    alert: "#dc2626",
    ok: "#16a34a",
  };

  function concernLink(tag: string | undefined): { label: string; href: string; icon: string } {
    switch (tag) {
      case "sucres":
        return { label: "Décoder les sucres cachés dans les produits bébé", href: "/encyclopedia", icon: "🍯" };
      case "additifs":
        return { label: "Encyclopédie des additifs : E471, E407, E150d", href: "/encyclopedia", icon: "🧪" };
      case "pesticides":
        return { label: "Classement bio et pesticides bébé", href: "/rankings", icon: "🌾" };
      case "nutrition":
        return { label: "Méthodologie : comment on note la nutrition réelle", href: "/methodology", icon: "📊" };
      case "allergenes":
        return { label: "Introduire les allergènes : les bonnes fenêtres", href: "/encyclopedia", icon: "🥜" };
      case "rappels":
        return { label: "Suivi des rappels RappelConso sur produits bébé", href: "/rankings", icon: "🚨" };
      default:
        return { label: "Explorer le classement complet BébéDécrypte", href: "/rankings", icon: "⭐" };
    }
  }

  function ageGuide(ageTag: string | undefined): { label: string; href: string; icon: string } {
    if (ageTag === "age-0-3") return { label: "Comparer les laits 1er âge notés A ou B", href: "/rankings", icon: "🍼" };
    if (ageTag === "age-4-5") return { label: "Démarrer la diversification : le guide complet", href: "/blog", icon: "🥄" };
    if (ageTag === "age-6-8") return { label: "Purées et petits pots : notre top 2026", href: "/rankings", icon: "🥕" };
    if (ageTag === "age-9-12") return { label: "Premiers morceaux : produits validés par les pédiatres", href: "/rankings", icon: "🍠" };
    if (ageTag === "age-12-24") return { label: "Repas famille et produits adaptés", href: "/rankings", icon: "🍝" };
    if (ageTag === "age-24") return { label: "Éviter les pièges du rayon enfant", href: "/blog", icon: "🧒" };
    return { label: "Catalogue de tous les produits notés", href: "/rankings", icon: "📖" };
  }

  function computeResult(answers: (Option | null)[]): Result {
    const vigilance = answers.reduce((s, a) => s + (a?.vigilance ?? 0), 0);
    const literacy = answers.reduce((s, a) => s + (a?.literacy ?? 0), 0);
    const industriel = answers.reduce((s, a) => s + (a?.industriel ?? 0), 0);
    const ageTag = answers[0]?.tag;
    const concernTag = answers[4]?.tag;

    let profile: Result;

    if (literacy >= 2 && vigilance >= 4) {
      profile = {
        id: "expert",
        emoji: "🧠",
        title: "Parent expert",
        text: "Tu décodes déjà les étiquettes comme un pro. Ton bébé est dans le top 10% des enfants français pour la qualité d'alimentation. On te propose d'aller encore plus loin : comparer les nuances entre marques bio premium et optimiser les 10% restants.",
        recommendations: [
          { label: "Comparateur détaillé des marques bio bébé", href: "/compare", icon: "⚖️" },
          ageGuide(ageTag),
          concernLink(concernTag),
        ],
        primaryCta: { label: "Voir le classement complet", href: "/rankings" },
        color: colors.ok,
      };
    } else if (literacy >= 1 && vigilance >= 3) {
      profile = {
        id: "vigilant",
        emoji: "🔎",
        title: "Parent vigilant",
        text: "Tu fais attention à ce que mange ton bébé et c'est visible. Il te manque juste les bons outils pour passer de « j'essaie bien » à « je sais exactement ». Notre classement et nos fiches additifs vont te faire gagner des heures de recherche.",
        recommendations: [
          { label: "Méthodologie de notation BébéDécrypte", href: "/methodology", icon: "📏" },
          ageGuide(ageTag),
          concernLink(concernTag),
        ],
        primaryCta: { label: "Découvrir le classement 2026", href: "/rankings" },
        color: colors.primary,
      };
    } else if (industriel >= 3 || (literacy === 0 && vigilance <= 2)) {
      profile = {
        id: "perdu",
        emoji: "🌀",
        title: "Parent perdu dans les rayons",
        text: "Tu n'es pas seul : 60% des parents français renoncent à lire les étiquettes bébé tellement elles sont complexes. Aucun jugement. On a construit BébéDécrypte exactement pour toi : une note claire de A à E, zéro jargon, les verdicts prêts à utiliser au supermarché.",
        recommendations: [
          { label: "Top 20 produits bébé notés A ou B", href: "/rankings", icon: "🏆" },
          ageGuide(ageTag),
          { label: "5 pièges à éviter au rayon bébé", href: "/blog", icon: "⚠️" },
        ],
        primaryCta: { label: "Voir les produits notés A", href: "/rankings" },
        color: colors.accent,
      };
    } else {
      profile = {
        id: "presse",
        emoji: "⏱️",
        title: "Parent pressé",
        text: "Tu sais que la qualité compte mais tu manques de temps pour décoder chaque étiquette. Notre classement te donne le verdict en 2 secondes par produit. Scan rapide, décision immédiate, zéro culpabilité au retour à la maison.",
        recommendations: [
          { label: "Top picks express par catégorie", href: "/rankings", icon: "⚡" },
          ageGuide(ageTag),
          concernLink(concernTag),
        ],
        primaryCta: { label: "Consulter le classement", href: "/rankings" },
        color: colors.primaryDark,
      };
    }

    return profile;
  }

  let currentQ = 0;
  const answers: (Option | null)[] = [null, null, null, null, null];

  const container = document.getElementById("quiz-question");
  const bar = document.getElementById("quiz-progress-bar");
  const pText = document.getElementById("quiz-progress-text");
  const sText = document.getElementById("quiz-score-text");

  function renderQuestion() {
    if (!container || !bar || !pText) return;
    const q = questions[currentQ];
    bar.style.width = `${(currentQ / questions.length) * 100}%`;
    pText.textContent = `Question ${currentQ + 1}/${questions.length}`;
    container.style.opacity = "0";
    container.style.transform = "translateY(8px)";
    setTimeout(() => {
      container.innerHTML = `
        <p class="font-semibold text-lg mb-6 leading-relaxed" style="letter-spacing:-0.01em;">${q.q}</p>
        <div class="space-y-2.5" id="opts" role="radiogroup" aria-label="${q.q.replace(/"/g, "&quot;")}">
          ${q.options.map((opt, i) => `
            <button class="quiz-opt w-full text-left px-4 py-3.5 rounded-xl border-2 border-gray-100 transition-all text-sm leading-relaxed group cursor-pointer" data-idx="${i}" role="radio" aria-checked="false" tabindex="${i === 0 ? 0 : -1}">
              <span class="inline-flex items-center gap-3">
                <span class="text-lg flex-shrink-0" aria-hidden="true">${opt.emoji}</span>
                <span class="group-hover:text-gray-900 text-gray-600 transition-colors">${opt.text}</span>
              </span>
            </button>
          `).join("")}
        </div>
      `;
      requestAnimationFrame(() => {
        container.style.transition = "opacity 0.4s ease, transform 0.4s ease";
        container.style.opacity = "1";
        container.style.transform = "translateY(0)";
      });
      const opts = container.querySelectorAll(".quiz-opt") as NodeListOf<HTMLElement>;
      opts.forEach((opt, i) => {
        opt.style.opacity = "0";
        opt.style.transform = "translateX(-12px)";
        setTimeout(() => {
          opt.style.transition = "opacity 0.35s ease, transform 0.35s ease, border-color 0.15s, background 0.15s, box-shadow 0.15s";
          opt.style.opacity = "1";
          opt.style.transform = "translateX(0)";
        }, 60 + i * 60);
      });
      opts.forEach((opt) => {
        opt.addEventListener("mouseenter", () => {
          opt.style.borderColor = "rgba(8,145,178,0.3)";
          opt.style.boxShadow = "0 0 0 1px rgba(8,145,178,0.1)";
        });
        opt.addEventListener("mouseleave", () => {
          opt.style.borderColor = "";
          opt.style.boxShadow = "";
        });
        const select = () => {
          const idx = parseInt(opt.dataset.idx || "0");
          answers[currentQ] = q.options[idx];
          opts.forEach((o) => {
            o.style.opacity = "0.3";
            o.style.pointerEvents = "none";
            o.style.transform = "scale(0.98)";
            o.setAttribute("aria-checked", "false");
          });
          opt.style.opacity = "1";
          opt.style.transform = "scale(1.02)";
          opt.style.borderColor = "#0891b2";
          opt.style.background = "rgba(8,145,178,0.06)";
          opt.style.boxShadow = "0 0 0 2px rgba(8,145,178,0.18)";
          opt.setAttribute("aria-checked", "true");
          setTimeout(() => {
            currentQ++;
            if (currentQ < questions.length) renderQuestion();
            else renderResult();
          }, 500);
        };
        opt.addEventListener("click", select);
        opt.addEventListener("keydown", (e: KeyboardEvent) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            select();
          } else if (e.key === "ArrowDown" || e.key === "ArrowRight") {
            e.preventDefault();
            const all = Array.from(opts);
            const idx = all.indexOf(opt);
            const next = all[(idx + 1) % all.length];
            next.focus();
          } else if (e.key === "ArrowUp" || e.key === "ArrowLeft") {
            e.preventDefault();
            const all = Array.from(opts);
            const idx = all.indexOf(opt);
            const next = all[(idx - 1 + all.length) % all.length];
            next.focus();
          }
        });
      });
      const first = opts[0];
      if (first) first.focus({ preventScroll: true });
    }, 200);
  }

  function renderResult() {
    if (!container || !bar || !pText || !sText) return;
    bar.style.width = "100%";
    pText.textContent = "Terminé";
    const r = computeResult(answers);
    sText.textContent = `Profil : ${r.title}`;
    const title = document.getElementById("quiz-title");
    const subtitle = document.getElementById("quiz-subtitle");
    if (title) title.textContent = "Ton profil parent";
    if (subtitle) subtitle.textContent = "Voici tes 3 pistes prioritaires, calculées sur tes réponses.";
    container.style.opacity = "0";
    container.style.transform = "scale(0.96)";
    setTimeout(() => {
      const recosHtml = r.recommendations.map((rec) => `
        <a href="${rec.href}" class="flex items-center gap-3 px-4 py-3 rounded-xl border border-gray-100 hover:border-gray-200 hover:bg-gray-50 transition-all text-sm text-left group">
          <span class="text-xl flex-shrink-0" aria-hidden="true">${rec.icon}</span>
          <span class="flex-1 text-gray-700 group-hover:text-gray-900">${rec.label}</span>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      `).join("");

      container.innerHTML = `
        <div class="py-4">
          <div class="text-center">
            <div class="text-6xl mb-4" aria-hidden="true">${r.emoji}</div>
            <h3 class="text-2xl md:text-3xl font-bold mb-3" style="color:${r.color}; letter-spacing:-0.03em;">${r.title}</h3>
            <p class="text-gray-500 leading-relaxed mb-6 max-w-lg mx-auto">${r.text}</p>
          </div>
          <div class="space-y-2 mb-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2 text-center">Tes 3 pistes pour ton bébé</p>
            ${recosHtml}
          </div>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="${r.primaryCta.href}" class="inline-flex items-center justify-center gap-2 text-white font-semibold px-7 py-3.5 rounded-full transition-all hover:scale-[1.03] active:scale-[0.98] text-sm" style="background:${r.color}; box-shadow: 0 2px 4px 0 rgba(255,255,255,0.3) inset, 0 4px 15px -3px ${r.color}40;">
              ${r.primaryCta.label}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
            <button id="quiz-restart" class="inline-flex items-center justify-center gap-2 text-gray-500 font-medium px-6 py-3 rounded-full border border-gray-200 hover:border-gray-300 hover:text-gray-700 transition-all text-sm">
              Recommencer le diagnostic
            </button>
          </div>
          <p class="text-xs text-gray-400 mt-6 text-center">100% gratuit. Aucun produit à vendre. Aucun email demandé.</p>
        </div>
      `;
      requestAnimationFrame(() => {
        container.style.transition = "opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1)";
        container.style.opacity = "1";
        container.style.transform = "scale(1)";
      });
      document.getElementById("quiz-restart")?.addEventListener("click", () => {
        currentQ = 0;
        for (let i = 0; i < answers.length; i++) answers[i] = null;
        if (sText) sText.textContent = "";
        if (title) title.textContent = "Ton bébé mange-t-il bien ? Diagnostic en 5 questions";
        if (subtitle) subtitle.textContent = "5 questions, 1 minute. Zéro inscription, zéro email.";
        renderQuestion();
      });
    }, 250);
  }

  renderQuestion();
</script>
