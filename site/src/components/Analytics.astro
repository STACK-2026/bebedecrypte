---
// Analytics tracker , Supabase page_views + bot detection.
//
// Fail-closed : reads PUBLIC_SUPABASE_URL + PUBLIC_SUPABASE_ANON_KEY from the
// build environment (CF Pages env vars). If either is missing OR the URL does
// not match the pinned BébéDécrypte project ref, the tracker renders nothing
// and logs a build warning. This guarantees no cross-project data leak, even
// if someone copies the file from another STACK-2026 repo.

const EXPECTED_PROJECT_REF = "feqdpvahksbamwutazkl"; // BébéDécrypte Supabase, pinned

const rawUrl = import.meta.env.PUBLIC_SUPABASE_URL as string | undefined;
const rawKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string | undefined;

function isValidBebedecrypteSupabase(url: string | undefined): url is string {
  if (!url) return false;
  try {
    const host = new URL(url).hostname;
    return host === `${EXPECTED_PROJECT_REF}.supabase.co`;
  } catch {
    return false;
  }
}

const ok = isValidBebedecrypteSupabase(rawUrl) && !!rawKey;

if (!ok) {
  // eslint-disable-next-line no-console
  console.warn(
    `[Analytics] disabled , expected PUBLIC_SUPABASE_URL=https://${EXPECTED_PROJECT_REF}.supabase.co, got ${rawUrl ?? "(unset)"}. No tracking will be sent.`
  );
}

const SB_URL = ok ? rawUrl : "";
const SB_ANON = ok ? rawKey : "";
---

{ok && (
  <script define:vars={{ SB_URL, SB_ANON }}>
{`
(function() {
  function isBot() {
    var ua = navigator.userAgent || "";
    return /bot|crawl|spider|slurp|facebookexternalhit|linkedinbot|twitterbot|whatsapp|telegram|googlebot|bingbot|yandex|baidu|duckduckbot|sogou|exabot|ia_archiver|semrush|ahrefs|mj12bot|dotbot|petalbot|bytespider|gptbot|claudebot|perplexitybot|amazonbot|applebot|ccbot/i.test(ua);
  }
  try {
    var raw = localStorage.getItem("ls_cookie_consent");
    if (raw) {
      var parsed = JSON.parse(raw);
      var MONTHS_13_MS = 13 * 30 * 24 * 60 * 60 * 1000;
      if (parsed && parsed.timestamp && Date.now() - parsed.timestamp > MONTHS_13_MS) return;
      if (parsed && parsed.status === "rejected") return;
    }
  } catch (e) { /* no storage */ }
  var bot = isBot();
  fetch(SB_URL + "/rest/v1/page_views", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "apikey": SB_ANON,
      "Authorization": "Bearer " + SB_ANON,
      "Prefer": "return=minimal"
    },
    body: JSON.stringify({
      path: window.location.pathname,
      referrer: document.referrer || null,
      user_agent: navigator.userAgent,
      is_bot: bot
    })
  }).catch(function() {});
})();
`}
  </script>
)}
