---
/**
 * DecodeReveal , BébéDécrypte signature text effect.
 *
 * Markup-only component: a single <span> annotated with data-* attributes.
 * The JS initializer is in BaseLayout.astro (global, one instance per page)
 * so nothing leaks inside parent elements like <h1>.
 */
interface Props {
  text: string;
  speed?: number;
  frames?: number;
  class?: string;
  trigger?: "load" | "scroll" | "hover";
}

const {
  text,
  speed = 55,
  frames = 26,
  class: className = "",
  trigger = "scroll",
} = Astro.props;
---

<span
  class={`decode-reveal ${className}`.trim()}
  data-decode-text={text}
  data-decode-speed={speed}
  data-decode-frames={frames}
  data-decode-trigger={trigger}
  aria-label={text}
  style="display:inline-block;min-width:0.5ch;font-variant-numeric:tabular-nums;white-space:pre;"
>{text}</span>
