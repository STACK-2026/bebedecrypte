---
import { siteConfig } from "../../site.config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import EasterEggs from "../components/EasterEggs.astro";
import Analytics from "../components/Analytics.astro";
import { getLocale } from "../i18n/t";
import { organizationSchema, websiteSchema } from "../lib/structured-data";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  jsonLd?: object | object[];
  noIndex?: boolean;
  // Set false on FR-only pages (products, brands, categories) to suppress
  // the hreflang en alternate, since /en/* counterparts do not exist.
  localized?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = siteConfig.ogImage,
  ogType = "website",
  publishedTime,
  jsonLd,
  noIndex = false,
  localized = true,
} = Astro.props;

const locale = getLocale(Astro.url);
const htmlLang = locale === "fr" ? "fr-FR" : "en-US";
const ogLocale = locale === "fr" ? "fr_FR" : "en_US";

const imageUrl = ogImage?.startsWith("http") ? ogImage : `${siteConfig.url}${ogImage}`;
// Always inject Organization + WebSite schemas, then merge any page-specific JSON-LD
const baseJsonLd = [organizationSchema(), websiteSchema(locale)];
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdArray = [...baseJsonLd, ...pageJsonLd];

// Build hreflang pairs (FR is default at root, EN under /en/)
const cleanPath = Astro.url.pathname.replace(/^\/en/, "") || "/";
const frHref = siteConfig.url + cleanPath;
const enHref = siteConfig.url + "/en" + (cleanPath === "/" ? "/" : cleanPath);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="author" content={siteConfig.author} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Hreflang (bilingual FR default + EN). Suppressed for FR-only pages. -->
    <link rel="alternate" hreflang="fr" href={frHref} />
    {localized && <link rel="alternate" hreflang="en" href={enHref} />}
    <link rel="alternate" hreflang="x-default" href={frHref} />
    <link rel="alternate" type="application/rss+xml" title="BébéDécrypte Blog (FR)" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="BébéDécrypte Blog (EN)" href="/en/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={siteConfig.name} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Analytics tracker , gated on env PUBLIC_SUPABASE_URL matching the
         BébéDécrypte project. No inline URL fallback : prevents cross-project leaks. -->
    <Analytics />

    <!-- Favicon + PWA -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#0891b2" />

    <!-- JSON-LD -->
    {jsonLdArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <EasterEggs />

    <script is:inline>
      // Reveal-on-scroll (inline for immediate execution)
      document.addEventListener("DOMContentLoaded", function() {
        var revealEls = document.querySelectorAll(".reveal, .fade-up, .scale-reveal, .blur-reveal, .slide-left, .slide-right, .clip-reveal, .split-words");

        // If page loaded with a hash, reveal the targeted element and its
        // reveal ancestors/siblings immediately so deep links never land on
        // an invisible section.
        if (location.hash && location.hash.length > 1) {
          try {
            var hashEl = document.querySelector(location.hash);
            if (hashEl) {
              var el = hashEl;
              while (el) {
                if (el.classList && el.classList.contains("reveal")) el.classList.add("in-view");
                el = el.parentElement;
              }
              var container = hashEl.parentElement;
              if (container) {
                Array.prototype.forEach.call(container.children, function(s) {
                  if (s.classList && s.classList.contains("reveal")) s.classList.add("in-view");
                });
              }
            }
          } catch (e) {}
        }

        if ("IntersectionObserver" in window && revealEls.length) {
          var io = new IntersectionObserver(
            function(entries) {
              entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("in-view");
                  io.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.08, rootMargin: "0px 0px -30px 0px" }
          );
          revealEls.forEach(function(el) {
            if (el.classList.contains("in-view")) return;
            io.observe(el);
          });
        } else {
          revealEls.forEach(function(el) { el.classList.add("in-view"); });
        }

        // Count-up
        var counters = document.querySelectorAll("[data-count-up]");
        if (counters.length && "IntersectionObserver" in window) {
          var cio = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (!entry.isIntersecting) return;
              var el = entry.target;
              var target = parseInt(el.getAttribute("data-count-up") || "0", 10);
              var duration = 1400;
              var startTime = performance.now();
              function tick(now) {
                var progress = Math.min(1, (now - startTime) / duration);
                var eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = Math.round(target * eased).toLocaleString();
                if (progress < 1) requestAnimationFrame(tick);
              }
              requestAnimationFrame(tick);
              cio.unobserve(el);
            });
          }, { threshold: 0.5 });
          counters.forEach(function(c) { cio.observe(c); });
        }

        // Stagger children reveal on scroll
        var staggerEls = document.querySelectorAll(".stagger-children");
        if (staggerEls.length && "IntersectionObserver" in window) {
          var sio = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");
                sio.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1 });
          staggerEls.forEach(function(el) { sio.observe(el); });
        }

        // Subtle parallax on scroll
        var parallaxEls = document.querySelectorAll(".parallax-slow");
        if (parallaxEls.length && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          window.addEventListener("scroll", function() {
            var y = window.scrollY;
            parallaxEls.forEach(function(el) {
              var speed = parseFloat(el.getAttribute("data-parallax-speed") || "0.15");
              el.style.transform = "translateY(" + (y * speed) + "px)";
            });
          }, { passive: true });
        }

        // DecodeReveal initializer (signature text effect, global)
        var decodeEls = document.querySelectorAll(".decode-reveal:not([data-decode-init])");
        if (decodeEls.length) {
          var DR_SINGLE = "ABCDEFGHJKLMNOPRSTUVWXYZabcdefhijklmnprstuvwxyz0123456789*/";
          var DR_REDUCED = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

          function drPlay(el, target, speed, frames) {
            var frame = 0;
            var interval = setInterval(function() {
              frame++;
              var progress = frame / frames;
              var resolvedLen = Math.floor(progress * target.length);
              var out = "";
              for (var i = 0; i < target.length; i++) {
                if (i < resolvedLen) out += target[i];
                else if (target[i] === " ") out += " ";
                else out += DR_SINGLE[Math.floor(Math.random() * DR_SINGLE.length)];
              }
              el.textContent = out;
              if (frame >= frames) {
                clearInterval(interval);
                el.textContent = target;
              }
            }, speed);
          }

          decodeEls.forEach(function(el) {
            el.setAttribute("data-decode-init", "1");
            var target = el.getAttribute("data-decode-text") || "";
            var speed = parseInt(el.getAttribute("data-decode-speed") || "55", 10);
            var frames = parseInt(el.getAttribute("data-decode-frames") || "26", 10);
            var trigger = el.getAttribute("data-decode-trigger") || "scroll";

            if (DR_REDUCED) { el.textContent = target; return; }

            if (trigger === "load") {
              drPlay(el, target, speed, frames);
            } else if (trigger === "hover") {
              el.addEventListener("mouseenter", function() { drPlay(el, target, speed, frames); });
            } else if ("IntersectionObserver" in window) {
              var dio = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                  if (entry.isIntersecting) {
                    drPlay(entry.target, target, speed, frames);
                    dio.unobserve(entry.target);
                  }
                });
              }, { threshold: 0.3 });
              dio.observe(el);
            } else {
              drPlay(el, target, speed, frames);
            }
          });
        }
      });
    </script>

    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--color-primary-dark);
        color: #ffffff;
        padding: 0.5rem 1rem;
        border-radius: 0 0 0.5rem 0;
        z-index: 100;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
  </body>
</html>
