# Global security + cache policy for bebedecrypte.com
# Cloudflare Pages: more specific patterns override conflicting headers,
# non-conflicting headers are merged.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400

# Astro hashed assets , safe to cache forever (filename-hashed)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Favicons and static OG assets
/favicon.svg
  Cache-Control: public, max-age=86400, s-maxage=604800
/og-default.svg
  Cache-Control: public, max-age=86400, s-maxage=604800

# XML feeds , fresh on CDN, fast revalidation
/sitemap-index.xml
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=86400
/sitemap-0.xml
  Cache-Control: public, max-age=300, s-maxage=86400, stale-while-revalidate=86400
/rss.xml
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=3600
/fr/rss.xml
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=3600

# AI crawler surface
/llms.txt
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400

/robots.txt
  Cache-Control: public, max-age=300, s-maxage=3600

# IndexNow challenge file , must be fetchable with minimal caching
/*.txt
  Cache-Control: public, max-age=300, s-maxage=3600
